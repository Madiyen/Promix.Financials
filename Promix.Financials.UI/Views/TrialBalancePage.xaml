<Page
    x:Class="Promix.Financials.UI.Views.TrialBalancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}"
    FlowDirection="RightToLeft"
    >

    <Page.Resources>
        <Style x:Key="TableHeaderTextStyle" TargetType="TextBlock" BasedOn="{StaticResource AppEnterpriseTableHeaderTextStyle}"/>

        <Style x:Key="TableCellTextStyle" TargetType="TextBlock" BasedOn="{StaticResource AppEnterpriseTableCellTextStyle}">
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="ReadableRadioStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="ReadableCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,20,24,20" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource AppSurfaceCardCompactStyle}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Left">
                        <Button Content="تحديث الميزان"
                                Style="{StaticResource PrimaryActionCompactButtonStyle}"
                                Click="LoadTrialBalance_Click"
                                IsEnabled="{Binding CanLoad}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Right">
                        <Border Style="{StaticResource AppEnterpriseInfoChipStyle}">
                            <TextBlock Text="{Binding TrialBalanceRangeText}"
                                       Style="{StaticResource AppEnterpriseInfoChipTextStyle}"/>
                        </Border>
                        <Border Style="{StaticResource AppEnterpriseInfoChipStyle}"
                                ToolTipService.ToolTip="{Binding PeriodLockHintText}">
                            <TextBlock Text="{Binding PeriodLockSummaryText}"
                                       Style="{StaticResource AppEnterpriseInfoChipTextStyle}"/>
                        </Border>
                        <Border Style="{StaticResource AppEnterpriseInfoChipStyle}">
                            <TextBlock Text="{Binding TrialBalanceRowsCountText}"
                                       Style="{StaticResource AppEnterpriseInfoChipTextStyle}"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource AppSurfaceCardCompactStyle}"
                    Visibility="{Binding ErrorVisibility}"
                    Background="#FEF2F2">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#B91C1C" TextWrapping="WrapWholeWords"/>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource AppSurfaceCardCompactStyle}">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="10" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="190"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="السنة المالية" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="TrialBalanceYearCombo"
                                      Style="{StaticResource InputComboBoxStyle}"
                                      ItemsSource="{Binding AvailableFiscalYears}"
                                      DisplayMemberPath="DisplayText"
                                      SelectedItem="{Binding SelectedFiscalYear, Mode=TwoWay}"
                                      SelectionChanged="TrialBalanceYearCombo_SelectionChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock Text="من تاريخ" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker Style="{StaticResource InputDatePickerStyle}"
                                        Date="{Binding FromDate, Mode=TwoWay}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock Text="إلى تاريخ" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker Style="{StaticResource InputDatePickerStyle}"
                                        Date="{Binding ToDate, Mode=TwoWay}"/>
                        </StackPanel>

                        <Border Grid.Column="3" Style="{StaticResource AppEnterpriseInnerCardStyle}">
                            <StackPanel Spacing="10">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="طريقة العرض" Style="{StaticResource FieldLabelStyle}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <RadioButton x:Name="SelectedPeriodModeRadio"
                                                     Content="الفترة المحددة"
                                                     GroupName="TrialBalanceMode"
                                                     Style="{StaticResource ReadableRadioStyle}"
                                                     IsChecked="True"
                                                     Checked="SelectedPeriodModeRadio_Checked"/>
                                        <RadioButton x:Name="LockedSnapshotModeRadio"
                                                     Content="حتى آخر إقفال"
                                                     GroupName="TrialBalanceMode"
                                                     Style="{StaticResource ReadableRadioStyle}"
                                                     IsEnabled="{Binding CanUseLockedSnapshot}"
                                                     Checked="LockedSnapshotModeRadio_Checked"/>
                                    </StackPanel>
                                </StackPanel>

                                <CheckBox Content="إظهار الحسابات ذات الأرصدة الصفرية"
                                          Style="{StaticResource ReadableCheckBoxStyle}"
                                          IsChecked="{Binding IncludeZeroBalanceRows, Mode=TwoWay}"
                                          Click="IncludeZeroRowsCheckBox_Click"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="اليوم"
                                Style="{StaticResource SecondaryActionCompactButtonStyle}"
                                Click="TodayRange_Click"/>
                        <Button Grid.Column="1"
                                Content="هذا الشهر"
                                Style="{StaticResource SecondaryActionCompactButtonStyle}"
                                Click="MonthRange_Click"/>
                        <Button Grid.Column="2"
                                Content="هذه السنة"
                                Style="{StaticResource SecondaryActionCompactButtonStyle}"
                                Click="YearRange_Click"/>

                        <Border Grid.Column="3" Style="{StaticResource AppEnterpriseInnerCardStyle}">
                            <StackPanel Spacing="3">
                                <TextBlock Text="{Binding TrialBalancePeriodStatusText}"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           FontWeight="SemiBold"
                                           TextWrapping="WrapWholeWords"/>
                                <TextBlock Text="{Binding NetBalanceSignHintText}"
                                           Foreground="{StaticResource SlateTextBrush}"
                                           FontSize="11.5"
                                           TextWrapping="WrapWholeWords"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid Grid.Row="3" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource AppMetricCardCompactStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="الأرصدة الافتتاحية" Style="{StaticResource AppMetricLabelTextStyle}"/>
                        <TextBlock Text="{Binding TrialBalanceOpeningTotalsText}"
                                   Style="{StaticResource AppMetricValueCompactTextStyle}"
                                   Foreground="#1E3A8A"
                                   Language="en-US"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource AppMetricCardCompactStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="حركة الفترة" Style="{StaticResource AppMetricLabelTextStyle}"/>
                        <TextBlock Text="{Binding TrialBalancePeriodTotalsText}"
                                   Style="{StaticResource AppMetricValueCompactTextStyle}"
                                   Foreground="#0F766E"
                                   Language="en-US"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource AppMetricCardCompactStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="الأرصدة الختامية" Style="{StaticResource AppMetricLabelTextStyle}"/>
                        <TextBlock Text="{Binding TrialBalanceClosingTotalsText}"
                                   Style="{StaticResource AppMetricValueCompactTextStyle}"
                                   Foreground="#0F172A"
                                   Language="en-US"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource AppMetricCardCompactStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="حالة الميزان" Style="{StaticResource AppMetricLabelTextStyle}"/>
                        <TextBlock Text="{Binding BalanceStateText}"
                                   Style="{StaticResource AppMetricValueCompactTextStyle}"
                                   Foreground="{Binding BalanceAccentBrush}"/>
                        <TextBlock Text="{Binding BalanceDifferenceLabelText}"
                                   Foreground="{Binding BalanceAccentBrush}"
                                   FontWeight="SemiBold"
                                   Language="en-US"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="4" Style="{StaticResource AppSurfaceCardCompactStyle}" Padding="0">
                <StackPanel>
                    <Grid Padding="16,14,16,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="4">
                            <TextBlock Text="حسابات ميزان المراجعة" Style="{StaticResource AppSectionTitleTextStyle}"/>
                            <TextBlock Text="{Binding BalanceHintText}"
                                       Style="{StaticResource AppSectionCaptionCompactTextStyle}"
                                       MaxWidth="520"
                                       ToolTipService.ToolTip="{Binding TrialBalanceSummaryText}"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding TrialBalanceRowsCountText}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SlateTextBrush}"
                                   FontWeight="SemiBold"/>
                    </Grid>

                    <Border Margin="16,0,16,16"
                            Style="{StaticResource AppEmptyStateCardStyle}"
                            Visibility="{Binding TrialBalanceEmptyVisibility}">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <TextBlock Text="لا توجد حسابات لعرضها"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="جرّب توسيع الفترة أو فعّل إظهار الأرصدة الصفرية أو غيّر طريقة العرض."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextAlignment="Center"
                                       TextWrapping="WrapWholeWords"
                                       MaxWidth="420"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Margin="16,0,16,16"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Visibility="{Binding TrialBalanceVisibility}">
                        <StackPanel MinWidth="1220">
                            <Border Style="{StaticResource AppEnterpriseTableHeaderSurfaceStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="الحساب" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="1" Text="الاسم" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="2" Text="افتتاحي مدين" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="3" Text="افتتاحي دائن" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="4" Text="حركة مدين" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="5" Text="حركة دائن" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="6" Text="ختامي مدين" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="7" Text="ختامي دائن" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="8" Text="صافي الرصيد" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="9" Text="الإجراء" Style="{StaticResource TableHeaderTextStyle}"/>
                                </Grid>
                            </Border>

                            <Rectangle Height="1" Fill="#E2E8F0" Margin="0,0,0,6"/>

                            <ItemsControl ItemsSource="{Binding TrialBalanceRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource AppEnterpriseDataRowStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="220"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="100"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Code}"
                                                           Style="{StaticResource TableCellTextStyle}"
                                                           FontWeight="SemiBold"
                                                           Language="en-US"/>

                                                <StackPanel Grid.Column="1" Spacing="3">
                                                    <TextBlock Text="{Binding NameAr}"
                                                               Style="{StaticResource TableCellTextStyle}"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding NatureText}"
                                                               Foreground="{Binding ClosingAccentBrush}"
                                                               FontSize="11"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="2" Text="{Binding OpeningDebitText}" Style="{StaticResource TableCellTextStyle}" HorizontalAlignment="Right" FontWeight="SemiBold" Language="en-US"/>
                                                <TextBlock Grid.Column="3" Text="{Binding OpeningCreditText}" Style="{StaticResource TableCellTextStyle}" HorizontalAlignment="Right" FontWeight="SemiBold" Language="en-US"/>
                                                <TextBlock Grid.Column="4" Text="{Binding PeriodDebitText}" Style="{StaticResource TableCellTextStyle}" HorizontalAlignment="Right" FontWeight="SemiBold" Language="en-US"/>
                                                <TextBlock Grid.Column="5" Text="{Binding PeriodCreditText}" Style="{StaticResource TableCellTextStyle}" HorizontalAlignment="Right" FontWeight="SemiBold" Language="en-US"/>
                                                <TextBlock Grid.Column="6" Text="{Binding ClosingDebitText}" Style="{StaticResource TableCellTextStyle}" HorizontalAlignment="Right" Foreground="{Binding ClosingAccentBrush}" FontWeight="SemiBold" Language="en-US"/>
                                                <TextBlock Grid.Column="7" Text="{Binding ClosingCreditText}" Style="{StaticResource TableCellTextStyle}" HorizontalAlignment="Right" Foreground="{Binding ClosingAccentBrush}" FontWeight="SemiBold" Language="en-US"/>
                                                <StackPanel Grid.Column="8" Spacing="3" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding NetClosingBalanceSignedText}"
                                                               Style="{StaticResource TableCellTextStyle}"
                                                               HorizontalAlignment="Right"
                                                               Foreground="{Binding NetClosingBalanceAccentBrush}"
                                                               FontWeight="SemiBold"
                                                               Language="en-US"/>
                                                    <TextBlock Text="{Binding NetClosingBalanceMeaningText}"
                                                               HorizontalAlignment="Right"
                                                               Foreground="{Binding NetClosingBalanceAccentBrush}"
                                                               FontSize="11"/>
                                                </StackPanel>

                                                <Button Grid.Column="9"
                                                        Content="كشف"
                                                        Style="{StaticResource SecondaryActionCompactButtonStyle}"
                                                        Click="OpenStatementFromTrialBalance_Click"
                                                        HorizontalAlignment="Left"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
