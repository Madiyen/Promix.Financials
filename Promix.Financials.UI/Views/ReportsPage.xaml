<Page
    x:Class="Promix.Financials.UI.Views.ReportsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:journalControls="using:Promix.Financials.UI.Controls.Journals"
    Background="{StaticResource AppBackgroundBrush}"
    FlowDirection="RightToLeft">

    <Page.Resources>
        <Style x:Key="SummaryValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
        </Style>

        <Style x:Key="TableHeaderTextStyle" TargetType="TextBlock" BasedOn="{StaticResource AppEnterpriseTableHeaderTextStyle}"/>

        <Style x:Key="TableCellTextStyle" TargetType="TextBlock" BasedOn="{StaticResource AppEnterpriseTableCellTextStyle}">
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,20,24,20" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource AppSurfaceCardCompactStyle}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top">
                        <Button Content="سند قبض"
                                Style="{StaticResource PrimaryActionCompactButtonStyle}"
                                Click="CreateReceiptVoucher_Click"
                                IsEnabled="{Binding CanLaunchVoucher}"/>
                        <Button Content="سند صرف"
                                Style="{StaticResource SecondaryActionCompactButtonStyle}"
                                Click="CreatePaymentVoucher_Click"
                                IsEnabled="{Binding CanLaunchVoucher}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Right">
                        <Border Style="{StaticResource AppEnterpriseInfoChipStyle}">
                            <TextBlock Text="{Binding AccountTitleText}"
                                       Style="{StaticResource AppEnterpriseInfoChipTextStyle}"/>
                        </Border>
                        <Border Style="{StaticResource AppEnterpriseInfoChipStyle}">
                            <TextBlock Text="{Binding PeriodSummaryText}"
                                       Style="{StaticResource AppEnterpriseInfoChipTextStyle}"/>
                        </Border>
                        <Border Style="{StaticResource AppEnterpriseInfoChipStyle}">
                            <TextBlock Text="{Binding PostedEntriesCountText}"
                                       Style="{StaticResource AppEnterpriseInfoChipTextStyle}"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource AppSurfaceCardCompactStyle}"
                    Visibility="{Binding ErrorVisibility}"
                    Background="#FEF2F2">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#B91C1C"
                           TextWrapping="WrapWholeWords"/>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource AppSurfaceCardCompactStyle}">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="10" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <journalControls:AccountLookupBox Grid.Column="0"
                                                          Header="الحساب"
                                                          PlaceholderText="ابحث بالكود أو الاسم"
                                                          ItemsSource="{Binding AccountOptions}"
                                                          SelectedAccountId="{Binding SelectedAccountId, Mode=TwoWay}"/>

                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock Text="السنة المالية" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="AccountStatementYearCombo"
                                      Style="{StaticResource InputComboBoxStyle}"
                                      ItemsSource="{Binding AvailableFiscalYears}"
                                      DisplayMemberPath="DisplayText"
                                      SelectedItem="{Binding SelectedFiscalYear, Mode=TwoWay}"
                                      SelectionChanged="AccountStatementYearCombo_SelectionChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock Text="من تاريخ" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker Style="{StaticResource InputDatePickerStyle}"
                                        Date="{Binding FromDate, Mode=TwoWay}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Spacing="6">
                            <TextBlock Text="إلى تاريخ" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker Style="{StaticResource InputDatePickerStyle}"
                                        Date="{Binding ToDate, Mode=TwoWay}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                            <Button Content="عرض الكشف"
                                    Style="{StaticResource PrimaryActionCompactButtonStyle}"
                                    Click="LoadStatement_Click"
                                    IsEnabled="{Binding CanLoad}"/>
                        </StackPanel>
                    </Grid>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="اليوم"
                                Style="{StaticResource SecondaryActionCompactButtonStyle}"
                                Click="TodayRange_Click"/>
                        <Button Grid.Column="1"
                                Content="هذا الشهر"
                                Style="{StaticResource SecondaryActionCompactButtonStyle}"
                                Click="MonthRange_Click"/>
                        <Button Grid.Column="2"
                                Content="هذه السنة"
                                Style="{StaticResource SecondaryActionCompactButtonStyle}"
                                Click="YearRange_Click"/>

                        <Border Grid.Column="3"
                                Style="{StaticResource AppEnterpriseInnerCardStyle}"
                                ToolTipService.ToolTip="{Binding PeriodLockHintText}">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE8D7;"
                                          Foreground="#0F766E"
                                          FontSize="16"
                                          VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="{Binding PeriodLockSummaryText}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryTextBrush}"/>
                                    <TextBlock Text="{Binding VoucherLaunchHintText}"
                                               Foreground="{StaticResource SlateTextBrush}"
                                               FontSize="11"
                                               TextWrapping="WrapWholeWords"
                                               MaxWidth="520"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid Grid.Row="3" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource AppMetricCardCompactStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="رصيد أول المدة" Style="{StaticResource AppMetricLabelTextStyle}"/>
                        <TextBlock Text="{Binding OpeningBalanceText}" Style="{StaticResource SummaryValueTextStyle}" Language="en-US"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource AppMetricCardCompactStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="إجمالي المدين" Style="{StaticResource AppMetricLabelTextStyle}"/>
                        <TextBlock Text="{Binding PeriodDebitText}"
                                   Style="{StaticResource SummaryValueTextStyle}"
                                   Foreground="#2563EB"
                                   Language="en-US"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource AppMetricCardCompactStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="إجمالي الدائن" Style="{StaticResource AppMetricLabelTextStyle}"/>
                        <TextBlock Text="{Binding PeriodCreditText}"
                                   Style="{StaticResource SummaryValueTextStyle}"
                                   Foreground="#059669"
                                   Language="en-US"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource AppMetricCardCompactStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="رصيد آخر المدة" Style="{StaticResource AppMetricLabelTextStyle}"/>
                        <TextBlock Text="{Binding ClosingBalanceText}" Style="{StaticResource SummaryValueTextStyle}" Language="en-US"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="4" Style="{StaticResource AppSurfaceCardCompactStyle}" Padding="0">
                <Border.Visibility>
                    <Binding Path="IsBusy" Converter="{StaticResource InverseBoolToVisibilityConverter}"/>
                </Border.Visibility>
                <StackPanel>
                    <Grid Padding="16,14,16,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="4">
                            <TextBlock Text="حركة الحساب" Style="{StaticResource AppSectionTitleTextStyle}"/>
                            <TextBlock Text="{Binding PeriodNetSummaryText}"
                                       Style="{StaticResource AppSectionCaptionCompactTextStyle}"
                                       MaxWidth="520"
                                       ToolTipService.ToolTip="{Binding MovementsSectionHintText}"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding RowsCountText}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SlateTextBrush}"
                                   FontWeight="SemiBold"/>
                    </Grid>

                    <Border Margin="16,0,16,12"
                            Style="{StaticResource AppEnterpriseInnerCardStyle}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding AccountTitleText}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding AccountNatureLabelText}"
                                       Foreground="{StaticResource SlateTextBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding NetPeriodMovementLabelText}"
                                       Foreground="{StaticResource SlateTextBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Margin="16,0,16,16"
                            Style="{StaticResource AppEmptyStateCardStyle}"
                            Visibility="{Binding EmptyStateVisibility}">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE9D2;"
                                      FontSize="34"
                                      Foreground="{StaticResource MutedTextBrush}"
                                      HorizontalAlignment="Center"/>
                            <TextBlock Text="لا توجد حركات لعرضها"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="اختر حسابًا وحدد الفترة ثم اضغط عرض الكشف، أو جرّب فترة أوسع."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextAlignment="Center"
                                       TextWrapping="WrapWholeWords"
                                       MaxWidth="420"/>
                            <Button Content="استخدم هذا الشهر"
                                    Style="{StaticResource SecondaryActionCompactButtonStyle}"
                                    Click="MonthRange_Click"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Margin="16,0,16,16"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Visibility="{Binding MovementsVisibility}">
                        <StackPanel MinWidth="1240">
                            <Border Style="{StaticResource AppEnterpriseTableHeaderSurfaceStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="170"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="التاريخ" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="1" Text="رقم السند" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="2" Text="النوع" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="3" Text="المرجع" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="4" Text="البيان" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="5" Text="مدين" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="6" Text="دائن" Style="{StaticResource TableHeaderTextStyle}"/>
                                    <TextBlock Grid.Column="7" Text="الرصيد الجاري" Style="{StaticResource TableHeaderTextStyle}"/>
                                </Grid>
                            </Border>

                            <Rectangle Height="1" Fill="#E2E8F0" Margin="0,0,0,6"/>

                            <ItemsControl ItemsSource="{Binding Movements}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource AppEnterpriseDataRowStyle}"
                                                Background="{Binding RowBackgroundBrush}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="170"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="{Binding EntryDateText}" Style="{StaticResource TableCellTextStyle}" Language="en-US"/>
                                                <HyperlinkButton Grid.Column="1"
                                                                 Content="{Binding EntryNumberDisplay}"
                                                                 Tag="{Binding}"
                                                                 Click="EntryNumberLink_Click"
                                                                 IsEnabled="{Binding CanOpenSourceEntry}"
                                                                 Padding="0"
                                                                 HorizontalAlignment="Left"
                                                                 FontSize="12"
                                                                 FontWeight="SemiBold"
                                                                 Foreground="{StaticResource PrimaryButtonBrush}"
                                                                 Language="en-US"/>
                                                <Border Grid.Column="2"
                                                        Background="{Binding TypeBackgroundBrush}"
                                                        CornerRadius="999"
                                                        HorizontalAlignment="Left"
                                                        Padding="10,4">
                                                    <TextBlock Text="{Binding TypeText}"
                                                               Foreground="{Binding TypeForegroundBrush}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                                <TextBlock Grid.Column="3" Text="{Binding ReferenceDisplay}" Style="{StaticResource TableCellTextStyle}" Language="en-US"/>
                                                <TextBlock Grid.Column="4" Text="{Binding DescriptionDisplay}" Style="{StaticResource TableCellTextStyle}" TextWrapping="WrapWholeWords"/>
                                                <TextBlock Grid.Column="5" Text="{Binding DebitText}" Style="{StaticResource TableCellTextStyle}" HorizontalAlignment="Right" FontWeight="SemiBold" FontSize="14" Language="en-US"/>
                                                <TextBlock Grid.Column="6" Text="{Binding CreditText}" Style="{StaticResource TableCellTextStyle}" HorizontalAlignment="Right" FontWeight="SemiBold" FontSize="14" Language="en-US"/>
                                                <TextBlock Grid.Column="7"
                                                           Text="{Binding RunningBalanceText}"
                                                           Style="{StaticResource TableCellTextStyle}"
                                                           Foreground="{Binding RunningBalanceBrush}"
                                                           FontWeight="SemiBold"
                                                           FontSize="14"
                                                           HorizontalAlignment="Right"
                                                           Language="en-US"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border Grid.Row="4"
                    Style="{StaticResource AppSurfaceCardCompactStyle}"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Spacing="14">
                    <Rectangle Height="18" RadiusX="9" RadiusY="9" Fill="#E2E8F0" Width="200" HorizontalAlignment="Right"/>
                    <Rectangle Height="28" RadiusX="10" RadiusY="10" Fill="#E5E7EB"/>
                    <Rectangle Height="28" RadiusX="10" RadiusY="10" Fill="#E2E8F0"/>
                    <Rectangle Height="28" RadiusX="10" RadiusY="10" Fill="#E5E7EB"/>
                    <Rectangle Height="28" RadiusX="10" RadiusY="10" Fill="#E2E8F0"/>
                    <Rectangle Height="28" RadiusX="10" RadiusY="10" Fill="#E5E7EB"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
