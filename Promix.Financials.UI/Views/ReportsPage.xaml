<Page
    x:Class="Promix.Financials.UI.Views.ReportsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:journalControls="using:Promix.Financials.UI.Controls.Journals"
    xmlns:reportModels="using:Promix.Financials.UI.ViewModels.Reports.Models"
    Background="{StaticResource AppBackgroundBrush}"
    FlowDirection="RightToLeft">

    <Page.Resources>
        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="SummaryValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
        </Style>

        <Style x:Key="TableHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource SlateTextBrush}"/>
        </Style>

        <Style x:Key="TableCellTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,20,24,24" RowSpacing="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="28" Padding="24" MinHeight="158">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0F172A" Offset="0"/>
                        <GradientStop Color="#1D4ED8" Offset="0.52"/>
                        <GradientStop Color="#38BDF8" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="270"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="10">
                        <TextBlock Text="كشف حساب" FontSize="28" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="راجع رصيد أول المدة، وحركة الحساب خلال الفترة، والرصيد الجاري بعد كل سند مرحل من شاشة واحدة."
                                   Foreground="#DBEAFE"
                                   FontSize="13"
                                   MaxWidth="720"
                                   TextWrapping="WrapWholeWords"/>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="{Binding AccountTitleText}" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="•" Foreground="#93C5FD"/>
                            <TextBlock Text="{Binding PeriodSummaryText}" Foreground="#BFDBFE" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="#0B1220"
                            CornerRadius="24"
                            Padding="18">
                        <StackPanel Spacing="8">
                            <TextBlock Text="ملخص سريع" Foreground="White" FontWeight="SemiBold"/>
                            <TextBlock Text="يعرض كشف الحساب أثر السندات المرحلة فقط. المسودات لا تؤثر على الرصيد الجاري."
                                       Foreground="#BFDBFE"
                                       FontSize="12"
                                       TextWrapping="WrapWholeWords"/>
                            <TextBlock Text="{Binding PostedEntriesCountText}" Foreground="White" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding AccountNatureLabelText}" Foreground="#BFDBFE" FontSize="12"/>
                            <TextBlock Text="{Binding NetPeriodMovementLabelText}" Foreground="#BFDBFE" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource PanelCardStyle}"
                    Visibility="{Binding ErrorVisibility}"
                    Background="#FEF2F2"
                    BorderBrush="#FECACA">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#B91C1C" TextWrapping="WrapWholeWords"/>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource PanelCardStyle}">
                <StackPanel Spacing="16">
                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <journalControls:AccountLookupBox Grid.Column="0"
                                                          Header="الحساب"
                                                          PlaceholderText="ابحث بالكود أو الاسم"
                                                          ItemsSource="{Binding AccountOptions}"
                                                          SelectedAccountId="{Binding SelectedAccountId, Mode=TwoWay}"/>

                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock Text="من تاريخ" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker Style="{StaticResource InputDatePickerStyle}"
                                        Date="{Binding FromDate, Mode=TwoWay}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock Text="إلى تاريخ" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker Style="{StaticResource InputDatePickerStyle}"
                                        Date="{Binding ToDate, Mode=TwoWay}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" VerticalAlignment="Bottom">
                            <Button Content="تحديث التقارير"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    Click="LoadStatement_Click"
                                    IsEnabled="{Binding CanLoadTrialBalance}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="اليوم"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Click="TodayRange_Click"/>
                        <Button Content="هذا الشهر"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Click="MonthRange_Click"/>
                        <Button Content="هذه السنة"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Click="YearRange_Click"/>
                    </StackPanel>

                    <Border Background="#F8FAFC"
                            BorderBrush="#DBEAFE"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="14">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="4">
                                <TextBlock Text="إضافة سند من نفس الحساب"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#0F172A"/>
                                <TextBlock Text="{Binding VoucherLaunchHintText}"
                                           Foreground="{StaticResource SlateTextBrush}"
                                           FontSize="12"
                                           TextWrapping="WrapWholeWords"
                                           MaxWidth="620"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="سند قبض"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    Click="CreateReceiptVoucher_Click"
                                    IsEnabled="{Binding CanLaunchVoucher}"
                                    Margin="0,0,0,0"/>

                            <Button Grid.Column="2"
                                    Content="سند صرف"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Click="CreatePaymentVoucher_Click"
                                    IsEnabled="{Binding CanLaunchVoucher}"
                                    Margin="0,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="14">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <FontIcon Glyph="&#xE8D7;"
                                      Foreground="#0F766E"
                                      FontSize="18"
                                      VerticalAlignment="Top"/>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="{Binding PeriodLockSummaryText}"
                                           FontWeight="SemiBold"
                                           Foreground="#0F172A"/>
                                <TextBlock Text="{Binding PeriodLockHintText}"
                                           Foreground="{StaticResource SlateTextBrush}"
                                           FontSize="12"
                                           TextWrapping="WrapWholeWords"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource PanelCardStyle}">
                <StackPanel Spacing="16">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="4">
                            <TextBlock Text="نبض النقدية" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="{Binding CashMovementSummaryText}"
                                       Foreground="{StaticResource SlateTextBrush}"
                                       FontSize="12"
                                       TextWrapping="WrapWholeWords"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding CashActiveDaysText}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SlateTextBrush}"
                                   FontWeight="SemiBold"/>
                    </Grid>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="18" Padding="14">
                            <StackPanel Spacing="6">
                                <TextBlock Text="إجمالي التدفق الداخل" Foreground="#047857"/>
                                <TextBlock Text="{Binding CashInflowText}" FontSize="24" FontWeight="Bold" Foreground="#065F46" Language="en-US"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="18" Padding="14">
                            <StackPanel Spacing="6">
                                <TextBlock Text="إجمالي التدفق الخارج" Foreground="#B91C1C"/>
                                <TextBlock Text="{Binding CashOutflowText}" FontSize="24" FontWeight="Bold" Foreground="#991B1B" Language="en-US"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="18" Padding="14">
                            <StackPanel Spacing="6">
                                <TextBlock Text="أعلى يوم دخول" Foreground="#1D4ED8"/>
                                <TextBlock Text="{Binding PeakCashInflowText}" FontSize="14" FontWeight="SemiBold" Foreground="#1E3A8A" TextWrapping="WrapWholeWords" Language="en-US"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3" Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="18" Padding="14">
                            <StackPanel Spacing="6">
                                <TextBlock Text="أعلى يوم خروج" Foreground="#C2410C"/>
                                <TextBlock Text="{Binding PeakCashOutflowText}" FontSize="14" FontWeight="SemiBold" Foreground="#9A3412" TextWrapping="WrapWholeWords" Language="en-US"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="14"
                            Visibility="{Binding CashMovementEmptyVisibility}">
                        <TextBlock Text="لا توجد حركة نقدية مرحلة خلال الفترة المحددة حتى الآن."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="WrapWholeWords"/>
                    </Border>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Visibility="{Binding CashMovementVisibility}">
                        <ItemsControl ItemsSource="{Binding CashMovementDays}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="10"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="reportModels:CashMovementDayVm">
                                    <Border Width="160"
                                            Margin="0,0,10,0"
                                            Background="{Binding AccentBackgroundBrush}"
                                            BorderBrush="{Binding AccentBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16"
                                            Padding="14,12">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{Binding FullDateText}"
                                                       Foreground="{Binding AccentBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Language="en-US"/>
                                            <TextBlock Text="{Binding DirectionText}"
                                                       Foreground="{Binding AccentBrush}"
                                                       FontSize="11"/>
                                            <TextBlock Text="{Binding NetMovementText}"
                                                       Foreground="#0F172A"
                                                       FontSize="22"
                                                       FontWeight="Bold"
                                                       Language="en-US"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource PanelCardStyle}">
                <StackPanel Spacing="16">
                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="190"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="السنة المالية" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="TrialBalanceYearCombo"
                                      Style="{StaticResource InputComboBoxStyle}"
                                      ItemsSource="{Binding AvailableFiscalYears}"
                                      SelectedItem="{Binding SelectedFiscalYear, Mode=TwoWay}"
                                      SelectionChanged="TrialBalanceYearCombo_SelectionChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock Text="طريقة العرض" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="TrialBalanceViewModeCombo"
                                      Style="{StaticResource InputComboBoxStyle}"
                                      SelectionChanged="TrialBalanceViewModeCombo_SelectionChanged"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="الفترة المحددة" Tag="selected"/>
                                <ComboBoxItem Content="حتى آخر إقفال" Tag="locked"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock Text="ميزان المراجعة" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="{Binding TrialBalanceSummaryText}"
                                       Foreground="{StaticResource SlateTextBrush}"
                                       FontSize="12"
                                       TextWrapping="WrapWholeWords"/>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="{Binding TrialBalanceRangeText}"
                                           Foreground="{StaticResource SlateTextBrush}"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding TrialBalancePeriodStatusText}"
                                           Foreground="#0F766E"
                                           FontSize="12"
                                           TextWrapping="WrapWholeWords"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="3" VerticalAlignment="Bottom" Spacing="8">
                            <CheckBox x:Name="IncludeZeroRowsCheckBox"
                                      Content="إظهار الأرصدة الصفرية"
                                      IsChecked="{Binding IncludeZeroBalanceRows, Mode=TwoWay}"
                                      Click="IncludeZeroRowsCheckBox_Click"/>
                            <Button Content="تحديث الميزان"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    Click="LoadTrialBalance_Click"
                                    IsEnabled="{Binding CanLoadTrialBalance}"/>
                        </StackPanel>
                    </Grid>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="18" Padding="14">
                            <StackPanel Spacing="6">
                                <TextBlock Text="إجمالي الرصيد المدين" Foreground="#1D4ED8"/>
                                <TextBlock Text="{Binding TrialBalanceDebitTotalText}" FontSize="24" FontWeight="Bold" Foreground="#1E3A8A" Language="en-US"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="18" Padding="14">
                            <StackPanel Spacing="6">
                                <TextBlock Text="إجمالي الرصيد الدائن" Foreground="#047857"/>
                                <TextBlock Text="{Binding TrialBalanceCreditTotalText}" FontSize="24" FontWeight="Bold" Foreground="#065F46" Language="en-US"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="18" Padding="14">
                            <StackPanel Spacing="6">
                                <TextBlock Text="الحسابات المعروضة" Foreground="{StaticResource SlateTextBrush}"/>
                                <TextBlock Text="{Binding TrialBalanceRowsCountText}" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="14"
                            Visibility="{Binding TrialBalanceEmptyVisibility}">
                        <TextBlock Text="لا توجد حسابات أو حركات مطابقة للفترة الحالية في ميزان المراجعة."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="WrapWholeWords"/>
                    </Border>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Visibility="{Binding TrialBalanceVisibility}">
                        <StackPanel MinWidth="1280">
                            <Grid Padding="10,10,10,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="250"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="الحساب" Style="{StaticResource TableHeaderTextStyle}"/>
                                <TextBlock Grid.Column="1" Text="الاسم" Style="{StaticResource TableHeaderTextStyle}"/>
                                <TextBlock Grid.Column="2" Text="افتتاحي مدين" Style="{StaticResource TableHeaderTextStyle}"/>
                                <TextBlock Grid.Column="3" Text="افتتاحي دائن" Style="{StaticResource TableHeaderTextStyle}"/>
                                <TextBlock Grid.Column="4" Text="حركة مدين" Style="{StaticResource TableHeaderTextStyle}"/>
                                <TextBlock Grid.Column="5" Text="حركة دائن" Style="{StaticResource TableHeaderTextStyle}"/>
                                <TextBlock Grid.Column="6" Text="ختامي مدين" Style="{StaticResource TableHeaderTextStyle}"/>
                                <TextBlock Grid.Column="7" Text="ختامي دائن" Style="{StaticResource TableHeaderTextStyle}"/>
                                <TextBlock Grid.Column="8" Text="الإجراء" Style="{StaticResource TableHeaderTextStyle}"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#E2E8F0" Margin="0,0,0,6"/>

                            <ItemsControl ItemsSource="{Binding TrialBalanceRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="reportModels:TrialBalanceRowVm">
                                        <Border Background="White"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="0,0,0,1"
                                                Padding="10,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="250"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="120"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="{Binding Code}" Style="{StaticResource TableCellTextStyle}" FontWeight="SemiBold" Language="en-US"/>
                                                <StackPanel Grid.Column="1" Spacing="3">
                                                    <TextBlock Text="{Binding NameAr}" Style="{StaticResource TableCellTextStyle}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding NatureText}" Foreground="{Binding ClosingAccentBrush}" FontSize="11"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding OpeningDebitText}" Style="{StaticResource TableCellTextStyle}" HorizontalAlignment="Right" Language="en-US"/>
                                                <TextBlock Grid.Column="3" Text="{Binding OpeningCreditText}" Style="{StaticResource TableCellTextStyle}" HorizontalAlignment="Right" Language="en-US"/>
                                                <TextBlock Grid.Column="4" Text="{Binding PeriodDebitText}" Style="{StaticResource TableCellTextStyle}" HorizontalAlignment="Right" Language="en-US"/>
                                                <TextBlock Grid.Column="5" Text="{Binding PeriodCreditText}" Style="{StaticResource TableCellTextStyle}" HorizontalAlignment="Right" Language="en-US"/>
                                                <TextBlock Grid.Column="6" Text="{Binding ClosingDebitText}" Style="{StaticResource TableCellTextStyle}" HorizontalAlignment="Right" Foreground="{Binding ClosingAccentBrush}" FontWeight="SemiBold" Language="en-US"/>
                                                <TextBlock Grid.Column="7" Text="{Binding ClosingCreditText}" Style="{StaticResource TableCellTextStyle}" HorizontalAlignment="Right" Foreground="{Binding ClosingAccentBrush}" FontWeight="SemiBold" Language="en-US"/>
                                                <Button Grid.Column="8"
                                                        Content="فتح الكشف"
                                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                                        Click="OpenStatementFromTrialBalance_Click"
                                                        HorizontalAlignment="Left"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Grid Grid.Row="5" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="رصيد أول المدة" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding OpeningBalanceText}" Style="{StaticResource SummaryValueTextStyle}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="إجمالي المدين" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding PeriodDebitText}" Style="{StaticResource SummaryValueTextStyle}" Foreground="#1D4ED8"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource PanelCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="إجمالي الدائن" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding PeriodCreditText}" Style="{StaticResource SummaryValueTextStyle}" Foreground="#047857"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource PanelCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="رصيد آخر المدة" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding ClosingBalanceText}" Style="{StaticResource SummaryValueTextStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="6" Style="{StaticResource PanelCardStyle}" Padding="0">
                <StackPanel>
                    <Grid Padding="18,16,18,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="4">
                            <TextBlock Text="حركة الحساب" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="{Binding MovementsSectionHintText}"
                                       Foreground="{StaticResource SlateTextBrush}"
                                       FontSize="12"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding RowsCountText}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SlateTextBrush}"
                                   FontWeight="SemiBold"/>
                    </Grid>

                    <Border Margin="18,0,18,12"
                            Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="14,10">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding AccountTitleText}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding AccountNatureLabelText}" Foreground="{StaticResource SlateTextBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding PeriodNetSummaryText}" Foreground="{StaticResource SlateTextBrush}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Margin="18,0,18,18"
                            Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="12"
                            Visibility="{Binding EmptyStateVisibility}">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <TextBlock Text="لا توجد حركات لعرضها" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Text="اختر حساباً وحدد الفترة ثم اضغط عرض الكشف، أو جرّب فترة أوسع."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextAlignment="Center"
                                       TextWrapping="WrapWholeWords"
                                       MaxWidth="420"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Margin="18,0,18,18"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Visibility="{Binding MovementsVisibility}">
                        <StackPanel MinWidth="1240">
                            <Grid Padding="10,10,10,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="170"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="التاريخ" Style="{StaticResource TableHeaderTextStyle}"/>
                                <TextBlock Grid.Column="1" Text="رقم السند" Style="{StaticResource TableHeaderTextStyle}"/>
                                <TextBlock Grid.Column="2" Text="النوع" Style="{StaticResource TableHeaderTextStyle}"/>
                                <TextBlock Grid.Column="3" Text="المرجع" Style="{StaticResource TableHeaderTextStyle}"/>
                                <TextBlock Grid.Column="4" Text="البيان" Style="{StaticResource TableHeaderTextStyle}"/>
                                <TextBlock Grid.Column="5" Text="مدين" Style="{StaticResource TableHeaderTextStyle}"/>
                                <TextBlock Grid.Column="6" Text="دائن" Style="{StaticResource TableHeaderTextStyle}"/>
                                <TextBlock Grid.Column="7" Text="الرصيد الجاري" Style="{StaticResource TableHeaderTextStyle}"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#E2E8F0" Margin="0,0,0,6"/>

                            <ItemsControl ItemsSource="{Binding Movements}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding RowBackgroundBrush}"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="0,0,0,1"
                                                Padding="10,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="170"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="{Binding EntryDateText}" Style="{StaticResource TableCellTextStyle}" Language="en-US"/>
                                                <TextBlock Grid.Column="1" Text="{Binding EntryNumberDisplay}" Style="{StaticResource TableCellTextStyle}" Language="en-US"/>
                                                <Border Grid.Column="2"
                                                        Background="{Binding TypeBackgroundBrush}"
                                                        CornerRadius="999"
                                                        HorizontalAlignment="Left"
                                                        Padding="10,4">
                                                    <TextBlock Text="{Binding TypeText}"
                                                               Foreground="{Binding TypeForegroundBrush}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                                <TextBlock Grid.Column="3" Text="{Binding ReferenceDisplay}" Style="{StaticResource TableCellTextStyle}" Language="en-US"/>
                                                <TextBlock Grid.Column="4" Text="{Binding DescriptionDisplay}" Style="{StaticResource TableCellTextStyle}" TextWrapping="WrapWholeWords"/>
                                                <TextBlock Grid.Column="5" Text="{Binding DebitText}" Style="{StaticResource TableCellTextStyle}" HorizontalAlignment="Right" Language="en-US"/>
                                                <TextBlock Grid.Column="6" Text="{Binding CreditText}" Style="{StaticResource TableCellTextStyle}" HorizontalAlignment="Right" Language="en-US"/>
                                                <TextBlock Grid.Column="7"
                                                           Text="{Binding RunningBalanceText}"
                                                           Style="{StaticResource TableCellTextStyle}"
                                                           Foreground="{Binding RunningBalanceBrush}"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Right"
                                                           Language="en-US"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
