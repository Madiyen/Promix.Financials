<Page
    x:Class="Promix.Financials.UI.Views.Ledger.FinancialYearsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}"
    FlowDirection="RightToLeft">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,20,24,20" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource AppSurfaceCardCompactStyle}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Left">
                        <Button Content="سنة مالية جديدة"
                                Style="{StaticResource PrimaryActionCompactButtonStyle}"
                                Click="CreateFinancialYear_Click"/>
                        <Button Content="تعديل"
                                Style="{StaticResource SecondaryActionCompactButtonStyle}"
                                Click="EditFinancialYear_Click"
                                IsEnabled="{Binding CanEditSelected}"/>
                        <Button Content="تفعيل"
                                Style="{StaticResource SecondaryActionCompactButtonStyle}"
                                Click="ActivateFinancialYear_Click"
                                IsEnabled="{Binding CanActivateSelected}"/>
                        <Button Content="تحديث"
                                Style="{StaticResource SecondaryActionCompactButtonStyle}"
                                Click="RefreshFinancialYears_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Right">
                        <Border Style="{StaticResource AppEnterpriseInfoChipStyle}">
                            <TextBlock Text="{Binding SummaryText}"
                                       Style="{StaticResource AppEnterpriseInfoChipTextStyle}"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <InfoBar Grid.Row="1"
                     IsOpen="{Binding HasError, Mode=OneWay}"
                     Severity="Error"
                     Title="تعذر تنفيذ العملية"
                     Message="{Binding ErrorMessage}"/>

            <InfoBar Grid.Row="2"
                     IsOpen="{Binding HasSuccess, Mode=OneWay}"
                     Severity="Success"
                     Title="تمت العملية"
                     Message="{Binding SuccessMessage}"/>

            <Grid Grid.Row="3" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource AppSurfaceCardCompactStyle}"
                        Padding="14">
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{Binding SummaryText}"
                                   Foreground="{StaticResource SlateTextBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>

                        <ListView Grid.Row="1"
                                  x:Name="FinancialYearsListView"
                                  Style="{StaticResource AppListViewStyle}"
                                  ItemsSource="{Binding Years}"
                                  SelectionChanged="FinancialYearsListView_SelectionChanged"
                                  SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource AppEnterpriseDataRowStyle}">
                                        <StackPanel Spacing="8">
                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"/>

                                                <Border Grid.Column="1"
                                                        Style="{StaticResource AppEnterpriseInfoChipStyle}">
                                                    <TextBlock Text="{Binding StatusText}"
                                                               Style="{StaticResource AppEnterpriseInfoChipTextStyle}"/>
                                                </Border>
                                            </Grid>

                                            <TextBlock Text="{Binding RangeText}"
                                                       Foreground="{StaticResource SlateTextBrush}"
                                                       FontSize="11.5"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource AppSurfaceCardCompactStyle}"
                        Padding="16">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding SelectedTitleText}"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       FontSize="20"
                                       FontWeight="Bold"/>
                            <TextBlock Text="{Binding SelectedRangeText}"
                                       Foreground="{StaticResource SlateTextBrush}"
                                       FontSize="12"/>
                        </StackPanel>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource AppEnterpriseInnerCardStyle}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="الحالة"
                                               Foreground="{StaticResource SlateTextBrush}"
                                               FontSize="11.5"/>
                                    <TextBlock Text="{Binding SelectedStatusText}"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               FontSize="15"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource AppEnterpriseInnerCardStyle}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="السياسة"
                                               Foreground="{StaticResource SlateTextBrush}"
                                               FontSize="11.5"/>
                                    <TextBlock Text="سنة واحدة نشطة فقط"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               FontSize="15"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource AppSurfaceCardCompactStyle}"
                                Padding="14">
                            <StackPanel Spacing="12">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0"
                                                Spacing="4"
                                                HorizontalAlignment="Right">
                                        <TextBlock Text="الفترات المالية"
                                                   Style="{StaticResource AppSectionTitleCompactTextStyle}"/>
                                        <TextBlock Text="{Binding PeriodsSummaryText}"
                                                   Style="{StaticResource AppSectionCaptionCompactTextStyle}"/>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Content="{Binding SelectedPeriodActionText}"
                                            Style="{StaticResource SecondaryActionCompactButtonStyle}"
                                            Click="ToggleFinancialPeriodStatus_Click"
                                            IsEnabled="{Binding CanToggleSelectedPeriod}"/>
                                </Grid>

                                <Border Style="{StaticResource AppEnterpriseInnerCardStyle}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding SelectedPeriodTitleText}"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SelectedPeriodRangeText}"
                                                   Foreground="{StaticResource SlateTextBrush}"
                                                   FontSize="11.5"/>
                                        <TextBlock Text="{Binding SelectedPeriodStatusText}"
                                                   Foreground="{StaticResource PrimaryButtonBrush}"
                                                   FontSize="11.5"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>

                                <ListView x:Name="FinancialPeriodsListView"
                                          Style="{StaticResource AppListViewStyle}"
                                          ItemsSource="{Binding Periods}"
                                          SelectionChanged="FinancialPeriodsListView_SelectionChanged"
                                          SelectedItem="{Binding SelectedPeriod, Mode=TwoWay}"
                                          MaxHeight="320">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource AppEnterpriseDataRowStyle}">
                                                <Grid ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0" Spacing="3">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding RangeText}"
                                                                   Foreground="{StaticResource SlateTextBrush}"
                                                                   FontSize="11.5"/>
                                                        <StackPanel Orientation="Horizontal"
                                                                    Spacing="8"
                                                                    HorizontalAlignment="Left">
                                                            <TextBlock Text="{Binding EntryCountText}"
                                                                       Foreground="{StaticResource PrimaryButtonBrush}"
                                                                       FontSize="10.5"
                                                                       FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding AdjustmentText}"
                                                                       Foreground="{StaticResource SlateTextBrush}"
                                                                       FontSize="10.5"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <Border Grid.Column="1"
                                                            Style="{StaticResource AppEnterpriseInfoChipStyle}"
                                                            VerticalAlignment="Top">
                                                        <TextBlock Text="{Binding StatusText}"
                                                                   Style="{StaticResource AppEnterpriseInfoChipTextStyle}"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
