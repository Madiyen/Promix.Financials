<Page
    x:Class="Promix.Financials.UI.Views.Ledger.FinancialYearsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}"
    FlowDirection="RightToLeft">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="18" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource AppSurfaceCardStyle}"
                    Padding="20,16">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Left">
                        <Button Content="سنة مالية جديدة"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Click="CreateFinancialYear_Click"/>
                        <Button Content="تعديل"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Click="EditFinancialYear_Click"
                                IsEnabled="{Binding CanEditSelected}"/>
                        <Button Content="تفعيل"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Click="ActivateFinancialYear_Click"
                                IsEnabled="{Binding CanActivateSelected}"/>
                        <Button Content="تحديث"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Click="RefreshFinancialYears_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Spacing="4"
                                HorizontalAlignment="Right">
                        <TextBlock Text="السنة المالية"
                                   Style="{StaticResource AppPageTitleTextStyle}"/>
                        <TextBlock Text="أنشئ السنوات المالية وفعّل سنة واحدة معتمدة للتقارير والتشغيل."
                                   Style="{StaticResource AppPageSubtitleTextStyle}"
                                   MaxWidth="640"/>
                    </StackPanel>
                </Grid>
            </Border>

            <InfoBar Grid.Row="1"
                     IsOpen="{Binding HasError, Mode=OneWay}"
                     Severity="Error"
                     Title="تعذر تنفيذ العملية"
                     Message="{Binding ErrorMessage}"/>

            <InfoBar Grid.Row="2"
                     IsOpen="{Binding HasSuccess, Mode=OneWay}"
                     Severity="Success"
                     Title="تمت العملية"
                     Message="{Binding SuccessMessage}"/>

            <Grid Grid.Row="3" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource AppSurfaceCardStyle}"
                        Padding="16">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{Binding SummaryText}"
                                   Foreground="{StaticResource SlateTextBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"/>

                        <ListView Grid.Row="1"
                                  x:Name="FinancialYearsListView"
                                  ItemsSource="{Binding Years}"
                                  SelectionChanged="FinancialYearsListView_SelectionChanged"
                                  SelectedItem="{Binding SelectedYear, Mode=TwoWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            CornerRadius="16"
                                            Padding="14"
                                            Margin="0,0,0,10"
                                            Background="White">
                                        <StackPanel Spacing="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"/>
                                                <Border Grid.Column="1"
                                                        Background="#ECFDF5"
                                                        BorderBrush="#A7F3D0"
                                                        BorderThickness="1"
                                                        CornerRadius="999"
                                                        Padding="10,4">
                                                    <TextBlock Text="{Binding StatusText}"
                                                               Foreground="#047857"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding RangeText}"
                                                       Foreground="{StaticResource SlateTextBrush}"
                                                       FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource AppSurfaceCardStyle}"
                        Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="{Binding SelectedTitleText}"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   FontSize="24"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding SelectedRangeText}"
                                   Foreground="{StaticResource SlateTextBrush}"
                                   FontSize="13"/>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="#F8FAFC"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="14">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="الحالة" Foreground="{StaticResource SlateTextBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding SelectedStatusText}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="18" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Background="#F8FAFC"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="14">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="السياسة" Foreground="{StaticResource SlateTextBrush}" FontSize="12"/>
                                    <TextBlock Text="سنة واحدة نشطة فقط" Foreground="{StaticResource PrimaryTextBrush}" FontSize="18" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="إرشادات سريعة"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="لا يسمح النظام بتداخل السنوات المالية داخل نفس الشركة."
                                           Foreground="{StaticResource SlateTextBrush}"
                                           FontSize="12"
                                           TextWrapping="WrapWholeWords"/>
                                <TextBlock Text="عند تفعيل سنة جديدة، تصبح هي السنة المعتمدة للتقارير والفلاتر المرتبطة بها."
                                           Foreground="{StaticResource SlateTextBrush}"
                                           FontSize="12"
                                           TextWrapping="WrapWholeWords"/>
                                <TextBlock Text="إذا لم تُعرَّف سنوات مالية بعد، ستستمر بعض الشاشات مؤقتًا بالاعتماد على السنوات المشتقة من القيود."
                                           Foreground="{StaticResource SlateTextBrush}"
                                           FontSize="12"
                                           TextWrapping="WrapWholeWords"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
