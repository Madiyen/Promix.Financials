<Page
    x:Class="Promix.Financials.UI.Views.Ledger.LedgerWorkspacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}"
    FlowDirection="RightToLeft">

    <Page.Resources>
        <Style x:Key="LedgerNavButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Background="Transparent">
                            <StackPanel Spacing="8" Padding="10,8,10,0">
                                <TextBlock x:Name="Label"
                                           Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           HorizontalAlignment="Center"/>
                                <Border x:Name="Underline"
                                        Height="2.5"
                                        CornerRadius="999"
                                        Background="#3B82F6"
                                        Opacity="0"/>
                            </StackPanel>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Padding="20,10,20,20" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrushStrong}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="8,6">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          ZoomMode="Disabled"
                          FlowDirection="RightToLeft">
                <StackPanel Orientation="Horizontal"
                            Spacing="2"
                            HorizontalAlignment="Right"
                            FlowDirection="RightToLeft">
                    <ToggleButton x:Name="AccountsTabButton"
                                  Style="{StaticResource LedgerNavButtonStyle}"
                                  Content="الحسابات"
                                  Tag="Accounts"
                                  Click="LedgerTabButton_Click"/>
                    <ToggleButton x:Name="JournalsTabButton"
                                  Style="{StaticResource LedgerNavButtonStyle}"
                                  Content="القيود والسندات"
                                  Tag="Journals"
                                  Click="LedgerTabButton_Click"/>
                    <ToggleButton x:Name="StatementTabButton"
                                  Style="{StaticResource LedgerNavButtonStyle}"
                                  Content="كشف الحساب"
                                  Tag="AccountStatement"
                                  Click="LedgerTabButton_Click"/>
                    <ToggleButton x:Name="TrialBalanceTabButton"
                                  Style="{StaticResource LedgerNavButtonStyle}"
                                  Content="ميزان المراجعة"
                                  Tag="TrialBalance"
                                  Click="LedgerTabButton_Click"/>
                    <ToggleButton x:Name="ReceivablesTabButton"
                                  Style="{StaticResource LedgerNavButtonStyle}"
                                  Content="الذمم"
                                  Tag="ReceivablesPayables"
                                  Click="LedgerTabButton_Click"/>
                    <ToggleButton x:Name="FinancialYearsTabButton"
                                  Style="{StaticResource LedgerNavButtonStyle}"
                                  Content="السنة المالية"
                                  Tag="FinancialYears"
                                  Margin="0"
                                  Click="LedgerTabButton_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="1">
            <Frame x:Name="AccountsFrame" Visibility="Collapsed"/>
            <Frame x:Name="JournalsFrame" Visibility="Collapsed"/>
            <Frame x:Name="StatementFrame" Visibility="Collapsed"/>
            <Frame x:Name="TrialBalanceFrame" Visibility="Collapsed"/>
            <Frame x:Name="ReceivablesFrame" Visibility="Collapsed"/>
            <Frame x:Name="FinancialYearsFrame" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Page>
