<Page
    x:Class="Promix.Financials.UI.Views.Journals.JournalEntriesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctcontrols="using:CommunityToolkit.WinUI.UI.Controls"
    Background="{StaticResource AppBackgroundBrush}"
    FlowDirection="RightToLeft">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,20,24,20" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource AppSurfaceCardCompactStyle}"
                    Padding="14,12">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center">
                            <Button Style="{StaticResource IconCompactButtonStyle}"
                                    Click="Refresh_Click"
                                    ToolTipService.ToolTip="{Binding LastRefreshedText}">
                                <FontIcon Glyph="&#xE72C;"/>
                            </Button>
                            <Button Content="ترحيل المحدد"
                                    Click="PostSelected_Click"
                                    IsEnabled="{Binding CanPostSelected}"
                                    Style="{StaticResource SecondaryActionCompactButtonStyle}"/>
                            <DropDownButton Content="+ إنشاء سند"
                                            Style="{StaticResource PrimaryActionCompactButtonStyle}">
                                <DropDownButton.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="سند قبض" Click="CreateReceipt_Click"/>
                                        <MenuFlyoutItem Text="سند صرف" Click="CreatePayment_Click"/>
                                        <MenuFlyoutItem Text="تحويل بين الحسابات" Click="CreateTransfer_Click"/>
                                        <MenuFlyoutItem Text="قيد يومية" Click="CreateDailyJournal_Click"/>
                                        <MenuFlyoutItem Text="قيد افتتاحي" Click="CreateOpeningEntry_Click"/>
                                        <MenuFlyoutItem Text="إقفال صندوق" Click="CreateDailyCashClosing_Click"/>
                                    </MenuFlyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                        </StackPanel>

                        <Grid Grid.Column="1" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.4*"/>
                                <ColumnDefinition Width="132"/>
                                <ColumnDefinition Width="132"/>
                                <ColumnDefinition Width="132"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="SearchFilterBox"
                                     Grid.Column="0"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     PlaceholderText="ابحث برقم السند أو المرجع أو الوصف"
                                     TextChanged="SearchFilterBox_TextChanged"/>

                            <ComboBox x:Name="TypeFilterCombo"
                                      Grid.Column="1"
                                      Style="{StaticResource InputComboBoxStyle}"
                                      SelectionChanged="TypeFilterCombo_SelectionChanged"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="كل الأنواع" Tag="all"/>
                                <ComboBoxItem Content="سند قبض" Tag="receipt"/>
                                <ComboBoxItem Content="سند صرف" Tag="payment"/>
                                <ComboBoxItem Content="تحويل" Tag="transfer"/>
                                <ComboBoxItem Content="قيد يومية" Tag="daily"/>
                                <ComboBoxItem Content="قيد افتتاحي" Tag="opening"/>
                                <ComboBoxItem Content="إقفال صندوق" Tag="closing"/>
                                <ComboBoxItem Content="قيد تسوية" Tag="adjustment"/>
                            </ComboBox>

                            <ComboBox x:Name="StatusFilterCombo"
                                      Grid.Column="2"
                                      Style="{StaticResource InputComboBoxStyle}"
                                      SelectionChanged="StatusFilterCombo_SelectionChanged"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="كل الحالات" Tag="all"/>
                                <ComboBoxItem Content="مرحل" Tag="posted"/>
                                <ComboBoxItem Content="مسودة" Tag="draft"/>
                            </ComboBox>

                            <ComboBox x:Name="PeriodFilterCombo"
                                      Grid.Column="3"
                                      Style="{StaticResource InputComboBoxStyle}"
                                      SelectionChanged="PeriodFilterCombo_SelectionChanged"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="كل الفترات" Tag="all"/>
                                <ComboBoxItem Content="اليوم" Tag="today"/>
                                <ComboBoxItem Content="آخر 7 أيام" Tag="week"/>
                                <ComboBoxItem Content="هذا الشهر" Tag="month"/>
                            </ComboBox>

                            <Button Grid.Column="4"
                                    Style="{StaticResource IconCompactButtonStyle}"
                                    Click="ClearFilters_Click"
                                    ToolTipService.ToolTip="مسح الفلاتر">
                                <FontIcon Glyph="&#xE894;"/>
                            </Button>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="1" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding ActiveFiltersText}"
                                   Style="{StaticResource AppSectionCaptionCompactTextStyle}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>

                        <Border Grid.Column="1"
                                Style="{StaticResource AppEnterpriseInfoChipStyle}"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding FilterSummaryText}"
                                       Style="{StaticResource AppEnterpriseInfoChipTextStyle}"/>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource AppMetricCardCompactStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="إجمالي السندات" Style="{StaticResource AppMetricLabelCompactTextStyle}"/>
                        <TextBlock Text="{Binding TotalEntriesText}" Style="{StaticResource AppMetricValueCompactTextStyle}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource AppMetricCardCompactStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="المرحل" Style="{StaticResource AppMetricLabelCompactTextStyle}"/>
                        <TextBlock Text="{Binding PostedEntriesText}" Style="{StaticResource AppMetricValueCompactTextStyle}" Foreground="#0369A1"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource AppMetricCardCompactStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="المسودات" Style="{StaticResource AppMetricLabelCompactTextStyle}"/>
                        <TextBlock Text="{Binding DraftEntriesText}" Style="{StaticResource AppMetricValueCompactTextStyle}" Foreground="#B45309"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource AppMetricCardCompactStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="صافي اليوم" Style="{StaticResource AppMetricLabelCompactTextStyle}"/>
                        <TextBlock Text="{Binding TodayNetMovementText}" Style="{StaticResource AppMetricValueCompactTextStyle}" Foreground="#2563EB"/>
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Grid.Row="2" Spacing="8">
                <Border x:Name="ErrorBanner" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="12" Padding="14,10" Visibility="Collapsed">
                    <TextBlock x:Name="ErrorBannerText" Foreground="#DC2626"/>
                </Border>
                <Border x:Name="SuccessBanner" Background="#ECFDF5" BorderBrush="#BBF7D0" BorderThickness="1" CornerRadius="12" Padding="14,10" Visibility="Collapsed">
                    <TextBlock x:Name="SuccessBannerText" Foreground="#166534"/>
                </Border>
            </StackPanel>

            <Border Grid.Row="3"
                    Style="{StaticResource AppSurfaceCardCompactStyle}"
                    Padding="0">
                <Grid>
                    <ctcontrols:DataGrid x:Name="EntriesDataGrid"
                                         ItemsSource="{Binding Entries}"
                                         SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                                         SelectionChanged="EntriesDataGrid_SelectionChanged"
                                         DoubleTapped="EntriesListView_DoubleTapped"
                                         KeyDown="EntriesListView_KeyDown"
                                         AutoGenerateColumns="False"
                                         IsReadOnly="True"
                                         CanUserSortColumns="False"
                                         HeadersVisibility="Column"
                                         GridLinesVisibility="Horizontal"
                                         RowDetailsVisibilityMode="VisibleWhenSelected"
                                         RowBackground="Transparent"
                                         AlternatingRowBackground="#FBFCFE"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         RowHeight="58"
                                         Visibility="{Binding EntriesVisibility}">
                        <ctcontrols:DataGrid.Columns>
                            <ctcontrols:DataGridTemplateColumn Header="الرقم" Width="160">
                                <ctcontrols:DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{Binding EntryNumber}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding ReferenceDisplay}" FontSize="11" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ctcontrols:DataGridTemplateColumn.CellTemplate>
                            </ctcontrols:DataGridTemplateColumn>
                            <ctcontrols:DataGridTextColumn Header="التاريخ" Width="130" Binding="{Binding EntryDateText}"/>
                            <ctcontrols:DataGridTemplateColumn Header="البيان" Width="*">
                                <ctcontrols:DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{Binding Description}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding LifecycleText}" FontSize="11" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ctcontrols:DataGridTemplateColumn.CellTemplate>
                            </ctcontrols:DataGridTemplateColumn>
                            <ctcontrols:DataGridTemplateColumn Header="النوع" Width="120">
                                <ctcontrols:DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding TypeBackgroundBrush}" CornerRadius="14" Padding="10,5" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding TypeText}" Foreground="{Binding TypeForegroundBrush}" FontSize="11" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </ctcontrols:DataGridTemplateColumn.CellTemplate>
                            </ctcontrols:DataGridTemplateColumn>
                            <ctcontrols:DataGridTemplateColumn Header="المبلغ" Width="140">
                                <ctcontrols:DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{Binding TotalDebitText}" Foreground="#1D4ED8" FontSize="14" FontWeight="SemiBold" Language="en-US"/>
                                            <TextBlock Text="{Binding CurrencySummaryText}" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Language="en-US"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ctcontrols:DataGridTemplateColumn.CellTemplate>
                            </ctcontrols:DataGridTemplateColumn>
                            <ctcontrols:DataGridTemplateColumn Header="الحالة" Width="110">
                                <ctcontrols:DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding StatusBackgroundBrush}" CornerRadius="14" Padding="10,5" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusForegroundBrush}" FontSize="11" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </ctcontrols:DataGridTemplateColumn.CellTemplate>
                            </ctcontrols:DataGridTemplateColumn>
                        </ctcontrols:DataGrid.Columns>
                        <ctcontrols:DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <Border Background="#F8FAFC" CornerRadius="0,0,12,12" Padding="16,12" Margin="12,0,12,12">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="الأثر المحاسبي للسند" Style="{StaticResource AppSectionTitleCompactTextStyle}"/>
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2.1*"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="2*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="الحساب" Style="{StaticResource AppEnterpriseTableHeaderTextStyle}"/>
                                            <TextBlock Grid.Column="1" Text="مدين" Style="{StaticResource AppEnterpriseTableHeaderTextStyle}"/>
                                            <TextBlock Grid.Column="2" Text="دائن" Style="{StaticResource AppEnterpriseTableHeaderTextStyle}"/>
                                            <TextBlock Grid.Column="3" Text="البيان" Style="{StaticResource AppEnterpriseTableHeaderTextStyle}"/>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{Binding DetailsLoadingVisibility}">
                                            <ProgressRing Width="18" Height="18" IsActive="True"/>
                                            <TextBlock Text="جاري تحميل أسطر القيد..." Style="{StaticResource AppSectionCaptionCompactTextStyle}"/>
                                        </StackPanel>
                                        <TextBlock Text="لا توجد تفاصيل أسطر متاحة لهذا السند." Visibility="{Binding DetailsEmptyVisibility}" Style="{StaticResource AppSectionCaptionCompactTextStyle}"/>
                                        <ItemsControl ItemsSource="{Binding Details}" Visibility="{Binding DetailsVisibility}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Spacing="6"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="White" CornerRadius="10" Padding="12,10">
                                                        <Grid ColumnSpacing="10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="2.1*"/>
                                                                <ColumnDefinition Width="120"/>
                                                                <ColumnDefinition Width="120"/>
                                                                <ColumnDefinition Width="2*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding AccountName}" FontWeight="SemiBold" TextWrapping="WrapWholeWords"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding DebitText}" FontSize="13.5" FontWeight="SemiBold" Foreground="#1D4ED8" Language="en-US"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding CreditText}" FontSize="13.5" FontWeight="SemiBold" Foreground="#0F172A" Language="en-US"/>
                                                            <TextBlock Grid.Column="3" Text="{Binding DescriptionText}" Foreground="{StaticResource SlateTextBrush}" TextWrapping="WrapWholeWords"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ctcontrols:DataGrid.RowDetailsTemplate>
                    </ctcontrols:DataGrid>
                    <Border x:Name="EmptyState" Background="Transparent" Visibility="{Binding EmptyStateVisibility}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                            <TextBlock Text="لا توجد سندات مطابقة" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="ابدأ بإنشاء سند جديد أو عدّل الفلاتر لإظهار النتائج." Foreground="{StaticResource MutedTextBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
