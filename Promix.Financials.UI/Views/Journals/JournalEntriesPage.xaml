<Page
    x:Class="Promix.Financials.UI.Views.Journals.JournalEntriesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctcontrols="using:CommunityToolkit.WinUI.UI.Controls"
    Background="{StaticResource AppBackgroundBrush}"
    FlowDirection="RightToLeft">

    <Page.Resources>
        <Style x:Key="JournalToolbarTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputTextBoxStyle}">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

        <Style x:Key="JournalToolbarComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource InputComboBoxStyle}">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="MinWidth" Value="98"/>
        </Style>

        <Style x:Key="JournalToolbarSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionCompactButtonStyle}">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style x:Key="JournalToolbarIconButtonStyle" TargetType="Button" BasedOn="{StaticResource IconCompactButtonStyle}">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="MinWidth" Value="34"/>
        </Style>

        <Style x:Key="JournalDetailsHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style x:Key="JournalEntryBadgeStyle" TargetType="Border" BasedOn="{StaticResource SoftBadgeStyle}">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="JournalEntryBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20,16,20,20" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="16"
                    BorderThickness="1"
                    BorderBrush="{StaticResource BorderBrushStrong}"
                    Padding="14,10">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBox x:Name="SearchFilterBox"
                                 Width="216"
                                 Style="{StaticResource JournalToolbarTextBoxStyle}"
                                 PlaceholderText="ابحث برقم السند أو المرجع أو الوصف"
                                 TextChanged="SearchFilterBox_TextChanged"/>

                        <ComboBox x:Name="TypeFilterCombo"
                                  Width="108"
                                  Style="{StaticResource JournalToolbarComboBoxStyle}"
                                  SelectionChanged="TypeFilterCombo_SelectionChanged"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="كل الأنواع" Tag="all"/>
                            <ComboBoxItem Content="سند قبض" Tag="receipt"/>
                            <ComboBoxItem Content="سند صرف" Tag="payment"/>
                            <ComboBoxItem Content="تحويل" Tag="transfer"/>
                            <ComboBoxItem Content="قيد يومية" Tag="daily"/>
                            <ComboBoxItem Content="قيد افتتاحي" Tag="opening"/>
                            <ComboBoxItem Content="إقفال صندوق" Tag="closing"/>
                            <ComboBoxItem Content="قيد تسوية" Tag="adjustment"/>
                        </ComboBox>

                        <ComboBox x:Name="StatusFilterCombo"
                                  Width="98"
                                  Style="{StaticResource JournalToolbarComboBoxStyle}"
                                  SelectionChanged="StatusFilterCombo_SelectionChanged"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="كل الحالات" Tag="all"/>
                            <ComboBoxItem Content="مرحل" Tag="posted"/>
                            <ComboBoxItem Content="مسودة" Tag="draft"/>
                        </ComboBox>

                        <ComboBox x:Name="PeriodFilterCombo"
                                  Width="108"
                                  Style="{StaticResource JournalToolbarComboBoxStyle}"
                                  SelectionChanged="PeriodFilterCombo_SelectionChanged"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="كل الفترات" Tag="all"/>
                            <ComboBoxItem Content="اليوم" Tag="today"/>
                            <ComboBoxItem Content="آخر 7 أيام" Tag="week"/>
                            <ComboBoxItem Content="هذا الشهر" Tag="month"/>
                        </ComboBox>

                        <Button Content="تطبيق"
                                Style="{StaticResource JournalToolbarSecondaryButtonStyle}"
                                Click="ApplyFilters_Click"/>

                        <Button Style="{StaticResource JournalToolbarIconButtonStyle}"
                                Click="ClearFilters_Click"
                                ToolTipService.ToolTip="مسح الفلاتر">
                            <FontIcon Glyph="&#xE894;"/>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource JournalToolbarIconButtonStyle}"
                                Click="Refresh_Click"
                                ToolTipService.ToolTip="تحديث البيانات">
                            <FontIcon Glyph="&#xE72C;"/>
                        </Button>
                        <Button Content="ترحيل"
                                Click="PostSelected_Click"
                                IsEnabled="{Binding CanPostSelected}"
                                Style="{StaticResource JournalToolbarSecondaryButtonStyle}"/>
                        <DropDownButton Content="+ إنشاء سند"
                                        MinHeight="34"
                                        Padding="10,0"
                                        Style="{StaticResource PrimaryActionCompactButtonStyle}">
                            <DropDownButton.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="سند قبض" Click="CreateReceipt_Click"/>
                                    <MenuFlyoutItem Text="سند صرف" Click="CreatePayment_Click"/>
                                    <MenuFlyoutItem Text="تحويل بين الحسابات" Click="CreateTransfer_Click"/>
                                    <MenuFlyoutItem Text="قيد يومية" Click="CreateDailyJournal_Click"/>
                                    <MenuFlyoutItem Text="قيد افتتاحي" Click="CreateOpeningEntry_Click"/>
                                    <MenuFlyoutItem Text="إقفال صندوق" Click="CreateDailyCashClosing_Click"/>
                                </MenuFlyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="16"
                    BorderThickness="1"
                    BorderBrush="{StaticResource BorderBrushStrong}"
                    Padding="0">
                <Grid ColumnSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Padding="14,10">
                        <StackPanel Spacing="4">
                            <TextBlock Text="إجمالي السندات" Style="{StaticResource AppMetricLabelCompactTextStyle}"/>
                            <TextBlock Text="{Binding TotalEntriesText}"
                                       Style="{StaticResource AppMetricValueCompactTextStyle}"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Rectangle Grid.Column="1" Fill="{StaticResource BorderBrushStrong}"/>

                    <Border Grid.Column="2" Padding="14,10">
                        <StackPanel Spacing="4">
                            <TextBlock Text="المرحل" Style="{StaticResource AppMetricLabelCompactTextStyle}"/>
                            <TextBlock Text="{Binding PostedEntriesText}"
                                       Style="{StaticResource AppMetricValueCompactTextStyle}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#166534"/>
                        </StackPanel>
                    </Border>

                    <Rectangle Grid.Column="3" Fill="{StaticResource BorderBrushStrong}"/>

                    <Border Grid.Column="4" Padding="14,10">
                        <StackPanel Spacing="4">
                            <TextBlock Text="المسودات" Style="{StaticResource AppMetricLabelCompactTextStyle}"/>
                            <TextBlock Text="{Binding DraftEntriesText}"
                                       Style="{StaticResource AppMetricValueCompactTextStyle}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#B45309"/>
                        </StackPanel>
                    </Border>

                    <Rectangle Grid.Column="5" Fill="{StaticResource BorderBrushStrong}"/>

                    <Border Grid.Column="6" Padding="14,10">
                        <StackPanel Spacing="4">
                            <TextBlock Text="صافي اليوم" Style="{StaticResource AppMetricLabelCompactTextStyle}"/>
                            <TextBlock Text="{Binding TodayNetMovementText}"
                                       Style="{StaticResource AppMetricValueCompactTextStyle}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#1D4ED8"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2" Spacing="8">
                <Border x:Name="ErrorBanner" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="12" Padding="14,10" Visibility="Collapsed">
                    <TextBlock x:Name="ErrorBannerText" Foreground="#B91C1C"/>
                </Border>
                <Border x:Name="SuccessBanner" Background="#ECFDF5" BorderBrush="#BBF7D0" BorderThickness="1" CornerRadius="12" Padding="14,10" Visibility="Collapsed">
                    <TextBlock x:Name="SuccessBannerText" Foreground="#166534"/>
                </Border>
            </StackPanel>

            <Border Grid.Row="3"
                    Background="{StaticResource CardBackgroundBrush}" CornerRadius="16" BorderThickness="1" BorderBrush="{StaticResource BorderBrushStrong}"
                    Padding="0">
                <Grid>
                    <ctcontrols:DataGrid x:Name="EntriesDataGrid"
                                         ItemsSource="{Binding Entries}"
                                         SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                                         SelectionChanged="EntriesDataGrid_SelectionChanged"
                                         LoadingRow="EntriesDataGrid_LoadingRow"
                                         UnloadingRow="EntriesDataGrid_UnloadingRow"
                                         DoubleTapped="EntriesListView_DoubleTapped"
                                         KeyDown="EntriesListView_KeyDown"
                                         AutoGenerateColumns="False"
                                         IsReadOnly="True"
                                         CanUserSortColumns="False"
                                         CanUserReorderColumns="False"
                                         CanUserResizeColumns="True"
                                         HeadersVisibility="Column"
                                         GridLinesVisibility="All"
                                         HorizontalGridLinesBrush="{StaticResource BorderBrushStrong}"
                                         VerticalGridLinesBrush="{StaticResource BorderBrushStrong}"
                                         RowDetailsVisibilityMode="VisibleWhenSelected"
                                         RowBackground="{StaticResource CardBackgroundBrush}"
                                         AlternatingRowBackground="{StaticResource CardSubtleBackgroundBrush}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{StaticResource PrimaryTextBrush}"
                                         RowHeight="52"
                                         ColumnHeaderHeight="40"
                                         Visibility="{Binding EntriesVisibility}">
                        <ctcontrols:DataGrid.Columns>
                            <ctcontrols:DataGridTemplateColumn Header="الرقم" Width="150">
                                <ctcontrols:DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding EntryNumber}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                                            <TextBlock Text="{Binding ReferenceDisplay}" FontSize="11" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ctcontrols:DataGridTemplateColumn.CellTemplate>
                            </ctcontrols:DataGridTemplateColumn>

                            <ctcontrols:DataGridTemplateColumn Header="التاريخ" Width="124">
                                <ctcontrols:DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding EntryDateText}"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   FontSize="12.5"
                                                   Language="en-US"/>
                                    </DataTemplate>
                                </ctcontrols:DataGridTemplateColumn.CellTemplate>
                            </ctcontrols:DataGridTemplateColumn>

                            <ctcontrols:DataGridTemplateColumn Header="البيان" Width="*">
                                <ctcontrols:DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Description}" Foreground="{StaticResource PrimaryTextBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding LifecycleText}" FontSize="11" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ctcontrols:DataGridTemplateColumn.CellTemplate>
                            </ctcontrols:DataGridTemplateColumn>

                            <ctcontrols:DataGridTemplateColumn Header="النوع" Width="118">
                                <ctcontrols:DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource JournalEntryBadgeStyle}"
                                                Background="{Binding TypeBackgroundBrush}">
                                            <TextBlock Text="{Binding TypeText}"
                                                       Style="{StaticResource JournalEntryBadgeTextStyle}"
                                                       Foreground="{Binding TypeForegroundBrush}"/>
                                        </Border>
                                    </DataTemplate>
                                </ctcontrols:DataGridTemplateColumn.CellTemplate>
                            </ctcontrols:DataGridTemplateColumn>

                            <ctcontrols:DataGridTemplateColumn Header="المبلغ" Width="140">
                                <ctcontrols:DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding TotalDebitText}" Foreground="#1D4ED8" FontSize="14.5" FontWeight="SemiBold" Language="en-US"/>
                                            <TextBlock Text="{Binding CurrencySummaryText}" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Language="en-US"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ctcontrols:DataGridTemplateColumn.CellTemplate>
                            </ctcontrols:DataGridTemplateColumn>

                            <ctcontrols:DataGridTemplateColumn Header="الحالة" Width="104">
                                <ctcontrols:DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource JournalEntryBadgeStyle}"
                                                Background="{Binding StatusBackgroundBrush}">
                                            <TextBlock Text="{Binding StatusText}"
                                                       Style="{StaticResource JournalEntryBadgeTextStyle}"
                                                       Foreground="{Binding StatusForegroundBrush}"/>
                                        </Border>
                                    </DataTemplate>
                                </ctcontrols:DataGridTemplateColumn.CellTemplate>
                            </ctcontrols:DataGridTemplateColumn>
                        </ctcontrols:DataGrid.Columns>

                        <ctcontrols:DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource CardSubtleBackgroundBrush}"
                                        CornerRadius="0,0,16,16"
                                        Padding="16,12"
                                        Margin="12,0,12,12">
                                    <Grid RowSpacing="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <TextBlock Text="الأثر المحاسبي للسند"
                                                       HorizontalAlignment="Right"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"/>
                                            <Button HorizontalAlignment="Left"
                                                    Style="{StaticResource IconCompactButtonStyle}"
                                                    Click="CloseRowDetails_Click"
                                                    ToolTipService.ToolTip="إغلاق التفاصيل">
                                                <FontIcon Glyph="&#xE711;" Foreground="{StaticResource SecondaryTextBrush}"/>
                                            </Button>
                                        </Grid>

                                        <Grid Grid.Row="1" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2.2*"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="2*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="الحساب" Style="{StaticResource JournalDetailsHeaderTextStyle}"/>
                                            <TextBlock Grid.Column="1" Text="مدين" Style="{StaticResource JournalDetailsHeaderTextStyle}"/>
                                            <TextBlock Grid.Column="2" Text="دائن" Style="{StaticResource JournalDetailsHeaderTextStyle}"/>
                                            <TextBlock Grid.Column="3" Text="البيان" Style="{StaticResource JournalDetailsHeaderTextStyle}"/>
                                        </Grid>

                                        <StackPanel Grid.Row="2"
                                                    Orientation="Horizontal"
                                                    Spacing="8"
                                                    Visibility="{Binding DetailsLoadingVisibility}">
                                            <ProgressRing Width="18" Height="18" IsActive="True"/>
                                            <TextBlock Text="جاري تحميل أسطر القيد..."
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       FontSize="12"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="3" Spacing="8">
                                            <TextBlock Text="لا توجد تفاصيل أسطر متاحة لهذا السند."
                                                       Visibility="{Binding DetailsEmptyVisibility}"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       FontSize="12"/>

                                            <ItemsControl ItemsSource="{Binding Details}" Visibility="{Binding DetailsVisibility}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Spacing="6"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{StaticResource CardBackgroundBrush}"
                                                                BorderBrush="{StaticResource BorderBrushStrong}"
                                                                BorderThickness="1"
                                                                CornerRadius="10"
                                                                Padding="12,10">
                                                            <Grid ColumnSpacing="10">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="2.2*"/>
                                                                    <ColumnDefinition Width="120"/>
                                                                    <ColumnDefinition Width="120"/>
                                                                    <ColumnDefinition Width="2*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{Binding AccountName}"
                                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                                           FontWeight="SemiBold"
                                                                           TextWrapping="WrapWholeWords"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding DebitText}"
                                                                           Foreground="#1D4ED8"
                                                                           FontSize="13.5"
                                                                           FontWeight="SemiBold"
                                                                           Language="en-US"/>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding CreditText}"
                                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                                           FontSize="13.5"
                                                                           FontWeight="SemiBold"
                                                                           Language="en-US"/>
                                                                <TextBlock Grid.Column="3"
                                                                           Text="{Binding DescriptionText}"
                                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                                           TextWrapping="WrapWholeWords"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ctcontrols:DataGrid.RowDetailsTemplate>
                    </ctcontrols:DataGrid>

                    <Border x:Name="EmptyState" Background="Transparent" Visibility="{Binding EmptyStateVisibility}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                            <FontIcon Glyph="&#xE14C;" FontSize="28" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="لا توجد سندات مطابقة" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBlock Text="ابدأ بإنشاء سند جديد أو عدّل الفلاتر لإظهار النتائج."
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>

