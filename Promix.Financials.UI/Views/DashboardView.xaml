<Page
    x:Class="Promix.Financials.UI.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Promix.Financials.UI.Controls"
    xmlns:journals="using:Promix.Financials.UI.ViewModels.Journals.Models"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- Modern SaaS Theme Palette -->
        <Color x:Key="SaaSPageBackground">#F1F5F9</Color>
        <Color x:Key="SaaSCardBackground">#FFFFFF</Color>
        <Color x:Key="SaaSTextPrimary">#0F172A</Color>
        <Color x:Key="SaaSTextSecondary">#64748B</Color>
        <Color x:Key="SaaSBorderFaint">#E2E8F0</Color>
        
        <SolidColorBrush x:Key="SaaSPageBackgroundBrush" Color="{StaticResource SaaSPageBackground}"/>
        <SolidColorBrush x:Key="SaaSCardBackgroundBrush" Color="{StaticResource SaaSCardBackground}"/>
        <SolidColorBrush x:Key="SaaSTextPrimaryBrush" Color="{StaticResource SaaSTextPrimary}"/>
        <SolidColorBrush x:Key="SaaSTextSecondaryBrush" Color="{StaticResource SaaSTextSecondary}"/>
        <SolidColorBrush x:Key="SaaSBorderFaintBrush" Color="{StaticResource SaaSBorderFaint}"/>

        <!-- Functional Minimalism Card Style -->
        <Style x:Key="SaaSCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SaaSCardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Shadow">
                <Setter.Value>
                    <ThemeShadow />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SaaSHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource SaaSTextPrimaryBrush}"/>
        </Style>

        <Style x:Key="SaaSSubtitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource SaaSTextSecondaryBrush}"/>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource SaaSPageBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="32" Padding="32">
                <!-- Top Area: Welcome Header -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock Text="نظرة عامة على البيانات" Style="{StaticResource SaaSHeaderTextStyle}"/>
                        <TextBlock Text="مرحباً بك مجدداً، إليك ملخص مالي لأداء الشركة اليوم." Style="{StaticResource SaaSSubtitleTextStyle}"/>
                    </StackPanel>
                    
                    <Border Grid.Column="1" 
                            Background="{StaticResource SaaSCardBackgroundBrush}"
                            Padding="16,8"
                            CornerRadius="8"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE787;" FontSize="14" Foreground="{StaticResource SaaSTextSecondaryBrush}"/>
                            <TextBlock Text="{Binding CurrentDateText}" Foreground="{StaticResource SaaSTextSecondaryBrush}" FontSize="13" FontWeight="Medium"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Row 1: KPI Summary Cards -->
                <controls:KpiCards/>

                <!-- Row 2: Split Layout -->
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Main Chart/Analytics Area -->
                    <Border Grid.Column="0" Style="{StaticResource SaaSCardStyle}">
                        <StackPanel Spacing="24">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="تحليلات التدفقات النقدية" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource SaaSTextPrimaryBrush}"/>
                                    <TextBlock Text="مقارنة بين الإيرادات والمصروفات خلال الأسبوع الحالي." Style="{StaticResource SaaSSubtitleTextStyle}"/>
                                </StackPanel>
                                <Border Grid.Column="1" 
                                        Background="#F8FAFC" 
                                        BorderBrush="{StaticResource SaaSBorderFaintBrush}" 
                                        BorderThickness="1" 
                                        CornerRadius="6" 
                                        Padding="12,6">
                                    <TextBlock Text="آخر 7 أيام" FontSize="12" FontWeight="Medium" Foreground="{StaticResource SaaSTextSecondaryBrush}"/>
                                </Border>
                            </Grid>

                            <!-- Weekly Cash Flow Visualization -->
                            <Grid Height="240">
                                <ItemsControl ItemsSource="{Binding ActivityBars}" VerticalAlignment="Bottom">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Center"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="journals:JournalActivityBarVm">
                                            <StackPanel Spacing="12" VerticalAlignment="Bottom">
                                                <Border Width="40" 
                                                        Height="{x:Bind BarHeight}" 
                                                        Background="{x:Bind FillBrush}" 
                                                        CornerRadius="6,6,2,2"
                                                        ToolTipService.ToolTip="{x:Bind ValueText}">
                                                </Border>
                                                <TextBlock Text="{x:Bind Label}" 
                                                           HorizontalAlignment="Center" 
                                                           FontSize="11" 
                                                           Foreground="{StaticResource SaaSTextSecondaryBrush}"
                                                           FontWeight="Medium"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                            
                            <!-- Legend -->
                            <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="8" Height="8" Fill="#10B981"/>
                                    <TextBlock Text="التدفق الداخل" FontSize="12" Foreground="{StaticResource SaaSTextSecondaryBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="8" Height="8" Fill="#EF4444"/>
                                    <TextBlock Text="التدفق الخارج" FontSize="12" Foreground="{StaticResource SaaSTextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Quick Actions Side Column -->
                    <controls:QuickActions Grid.Column="1"/>
                </Grid>

                <!-- Activity / Transactions -->
                <controls:TransactionsTable/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
