<Page
    x:Class="Promix.Financials.UI.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Promix.Financials.UI.Controls"
    xmlns:journals="using:Promix.Financials.UI.ViewModels.Journals.Models"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="DashboardSurfaceStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20" Padding="24,24,24,32">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="3">
                        <TextBlock Text="لوحة التحكم المالية"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MainTitleTextBrush}"/>
                        <TextBlock Text="السندات، التدفق النقدي، وآخر الحركات في مساحة عمل واحدة سريعة القراءة."
                                   FontSize="13"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrushStrong}"
                            BorderThickness="1"
                            Padding="14,8"
                            CornerRadius="10"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE787;" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}"/>
                            <TextBlock Text="{Binding CurrentDateText}"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <controls:KpiCards/>

                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.15*"/>
                        <ColumnDefinition Width="1.15*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource DashboardSurfaceStyle}">
                        <Grid RowSpacing="18">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="4" VerticalAlignment="Center">
                                    <TextBlock Text="حركة النقد هذا الأسبوع"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryTextBrush}"/>
                                    <TextBlock Text="قراءة مباشرة للدخول والخروج خلال آخر سبعة أيام."
                                               FontSize="13"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Margin="18,0,0,0"
                                            Spacing="2"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="إجمالي الداخل"
                                               FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                    <TextBlock Text="{Binding WeeklyCashInflowText}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#166534"
                                               Language="en-US"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            Margin="18,0,0,0"
                                            Spacing="2"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="إجمالي الخارج"
                                               FontSize="11"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                    <TextBlock Text="{Binding WeeklyCashOutflowText}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#B91C1C"
                                               Language="en-US"/>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="1"
                                    Background="{StaticResource CardSubtleBackgroundBrush}"
                                    CornerRadius="14"
                                    Padding="18"
                                    MinHeight="260">
                                <Grid>
                                    <Rectangle Height="1"
                                               VerticalAlignment="Bottom"
                                               Fill="{StaticResource BorderBrushStrong}"/>
                                    <ItemsControl ItemsSource="{Binding ActivityBars}" VerticalAlignment="Bottom">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="22"
                                                            HorizontalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="journals:JournalActivityBarVm">
                                                <StackPanel Spacing="10" VerticalAlignment="Bottom">
                                                    <TextBlock Text="{x:Bind ValueText}"
                                                               HorizontalAlignment="Center"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                                    <Border Width="42"
                                                            Height="{x:Bind BarHeight}"
                                                            Background="{x:Bind FillBrush}"
                                                            CornerRadius="8,8,3,3"
                                                            ToolTipService.ToolTip="{x:Bind ValueText}"/>
                                                    <TextBlock Text="{x:Bind Label}"
                                                               HorizontalAlignment="Center"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="2" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="{StaticResource CardSubtleBackgroundBrush}"
                                        CornerRadius="12"
                                        Padding="14,12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="سندات القبض" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}"/>
                                        <TextBlock Text="{Binding ReceiptShareText}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                                        Background="{StaticResource CardSubtleBackgroundBrush}"
                                        CornerRadius="12"
                                        Padding="14,12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="سندات الصرف" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}"/>
                                        <TextBlock Text="{Binding PaymentShareText}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Background="{StaticResource CardSubtleBackgroundBrush}"
                                        CornerRadius="12"
                                        Padding="14,12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="القيود اليومية" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}"/>
                                        <TextBlock Text="{Binding DailyShareText}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="3"
                                        Background="{StaticResource CardSubtleBackgroundBrush}"
                                        CornerRadius="12"
                                        Padding="14,12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="حركات أخرى" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}"/>
                                        <TextBlock Text="{Binding OtherShareText}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <controls:QuickActions x:Name="QuickActionsPanel"
                                           Grid.Column="1"/>
                </Grid>

                <controls:TransactionsTable/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
