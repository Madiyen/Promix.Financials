<UserControl
    x:Class="Promix.Financials.UI.Controls.Journals.AccountLookupBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root"
    RequestedTheme="Light">

    <StackPanel Spacing="6">
        <TextBlock Text="{Binding Header, ElementName=Root}"
                   Style="{StaticResource FieldLabelStyle}"/>

        <Grid RowSpacing="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="InputBorder"
                    Grid.Row="0"
                    Background="White"
                    BorderBrush="#94A3B8"
                    BorderThickness="1"
                    CornerRadius="10">
                <TextBox x:Name="SearchBox"
                         Style="{StaticResource SearchBoxStyle}"
                         PlaceholderText="{Binding PlaceholderText, ElementName=Root}"
                         TextChanged="SearchBox_TextChanged"
                         GotFocus="SearchBox_GotFocus"
                         LostFocus="SearchBox_LostFocus"
                         KeyDown="SearchBox_KeyDown"/>
            </Border>

            <Border x:Name="SuggestionsPanel"
                    Grid.Row="1"
                    Background="White"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="4"
                    Visibility="Collapsed">
                <ListView x:Name="SuggestionsList"
                          Background="Transparent"
                          BorderThickness="0"
                          IsItemClickEnabled="True"
                          ItemsSource="{Binding Suggestions, ElementName=Root}"
                          ItemClick="SuggestionsList_ItemClick"
                          KeyDown="SuggestionsList_KeyDown"
                          MaxHeight="220"
                          SelectionMode="Single">
                    <ListView.Resources>
                        <Style TargetType="ListViewItem"
                               BasedOn="{StaticResource AppSelectableListViewItemStyle}">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="MinHeight" Value="44"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.Resources>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="Transparent"
                                    Padding="10,8"
                                    CornerRadius="8">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Code}"
                                               Foreground="#1D4ED8"
                                               FontWeight="Bold"
                                               FontSize="13"
                                               Language="en-US"/>

                                    <StackPanel Grid.Column="1"
                                                Spacing="4">
                                        <TextBlock Text="{Binding NameAr}"
                                                   Foreground="#0F172A"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding NatureText}"
                                                   Foreground="#64748B"
                                                   FontSize="11"/>
                                    </StackPanel>

                                    <Border Grid.Column="2"
                                            Background="#EFF6FF"
                                            CornerRadius="10"
                                            Padding="8,4"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="{Binding CategoryText}"
                                                   Foreground="#1D4ED8"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </Grid>

        <TextBlock Text="{Binding SelectedCaption, ElementName=Root}"
                   Foreground="#475569"
                   FontSize="11"
                   Visibility="{Binding CaptionVisibility, ElementName=Root}"/>
    </StackPanel>
</UserControl>
