<UserControl
    x:Class="Promix.Financials.UI.Controls.AppHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Height="64"
          Background="{StaticResource CardBackgroundBrush}"
          BorderBrush="{StaticResource BorderBrushStrong}"
          BorderThickness="0,0,0,1"
          Padding="24,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="TitleText"
                       Text="لوحة القيادة"
                       Foreground="{StaticResource MainTitleTextBrush}"
                       FontWeight="SemiBold"
                       FontSize="18"/>
            <TextBlock x:Name="SubtitleText"
                       Text="ملخص سريع لأهم المؤشرات والحركات اليومية."
                       Foreground="{StaticResource MutedTextBrush}"
                       FontSize="11"
                       Margin="0,3,0,0"/>
        </StackPanel>

        <Border Grid.Column="1"
                VerticalAlignment="Center"
                Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12,7"
                Margin="14,0,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE787;"
                          Foreground="{StaticResource SlateTextBrush}"
                          FontSize="13"
                          VerticalAlignment="Center"/>
                <TextBlock x:Name="DateText"
                           Foreground="{StaticResource SlateTextBrush}"
                           FontSize="12"
                           FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="2"
                VerticalAlignment="Center"
                Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrushStrong}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="14,0"
                Height="40"
                Width="392"
                HorizontalAlignment="Center">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <FontIcon Glyph="&#xE721;"
                          Foreground="{StaticResource MutedTextBrush}"
                          FontSize="14"
                          VerticalAlignment="Center"/>

                <TextBox x:Name="SearchBox"
                         Grid.Column="1"
                         Margin="10,0,0,0"
                         Style="{StaticResource SearchBoxStyle}"
                         BorderThickness="0"
                         Background="Transparent"
                         VerticalAlignment="Center"
                         TextAlignment="Right"/>

                <Border Grid.Column="2"
                        Background="{StaticResource BorderBrushSoft}"
                        CornerRadius="6"
                        Padding="6,2"
                        VerticalAlignment="Center">
                    <TextBlock Text="Ctrl+K"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="10"
                               FontFamily="Consolas"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="3"
                x:Name="FiscalYearBadge"
                VerticalAlignment="Center"
                Margin="12,0,0,0"
                Background="#EFF6FF"
                BorderBrush="#DBEAFE"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12,7">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock x:Name="FiscalYearText"
                           Text="الفترة الحالية"
                           Foreground="{StaticResource PrimaryButtonBrush}"
                           FontSize="12.5"
                           FontWeight="SemiBold"/>
                <FontIcon Glyph="&#xE70D;"
                          Foreground="{StaticResource PrimaryButtonBrush}"
                          FontSize="12"
                          VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Column="4"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="14,0,0,0"
                    Spacing="10">
            <Button Width="40"
                    Height="40"
                    Style="{StaticResource IconButtonStyle}"
                    Click="Settings_Click"
                    ToolTipService.ToolTip="{x:Bind SettingsTooltip, Mode=OneTime}">
                <FontIcon Glyph="&#xE713;"
                          Foreground="{StaticResource SlateTextBrush}"
                          FontSize="16"/>
            </Button>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="38"
                        Height="38"
                        CornerRadius="19">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#3B82F6" Offset="0"/>
                            <GradientStop Color="#8B5CF6" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock x:Name="AvatarText"
                               Text="PM"
                               Foreground="White"
                               FontSize="12"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <FontIcon Grid.Column="1"
                          Glyph="&#xE70D;"
                          Foreground="{StaticResource MutedTextBrush}"
                          FontSize="12"
                          VerticalAlignment="Center"
                          Margin="8,0,0,0"/>
            </Grid>
        </StackPanel>

        <Rectangle Grid.ColumnSpan="5"
                   VerticalAlignment="Bottom"
                   Height="4"
                   IsHitTestVisible="False">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#120F172A" Offset="0"/>
                    <GradientStop Color="#000F172A" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</UserControl>
