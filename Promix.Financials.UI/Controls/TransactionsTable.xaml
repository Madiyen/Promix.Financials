<UserControl
    x:Class="Promix.Financials.UI.Controls.TransactionsTable"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:journals="using:Promix.Financials.UI.ViewModels.Journals.Models">

    <Border Style="{StaticResource AppSurfaceCardCompactStyle}" Padding="0">
        <StackPanel>
            <Grid Padding="16,14,16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="3">
                    <TextBlock Text="آخر الحركات" Style="{StaticResource AppSectionTitleTextStyle}"/>
                    <TextBlock Text="أحدث السندات والقيود المسجلة داخل الشركة الحالية."
                               Style="{StaticResource AppSectionCaptionCompactTextStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <Border Style="{StaticResource AppEnterpriseInfoChipStyle}">
                        <TextBlock Text="آخر 6 عناصر"
                                   Style="{StaticResource AppEnterpriseInfoChipTextStyle}"/>
                    </Border>
                </StackPanel>
            </Grid>

            <Border Visibility="{Binding EmptyEntriesVisibility}"
                    Margin="16,0,16,16"
                    Style="{StaticResource AppEmptyStateCardStyle}">
                <StackPanel Spacing="6">
                    <TextBlock Text="لا توجد حركات بعد" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="ابدأ بسند قبض أو صرف أو قيد يومية، وستظهر آخر الحركات هنا تلقائيًا."
                               Foreground="{StaticResource SlateTextBrush}"
                               FontSize="11.5"
                               TextWrapping="WrapWholeWords"/>
                </StackPanel>
            </Border>

            <StackPanel Visibility="{Binding RecentEntriesVisibility}">
                <Border Style="{StaticResource AppEnterpriseTableHeaderSurfaceStyle}" Margin="16,0,16,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="105"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="الرقم" Style="{StaticResource AppEnterpriseTableHeaderTextStyle}"/>
                        <TextBlock Grid.Column="1" Text="التاريخ" Style="{StaticResource AppEnterpriseTableHeaderTextStyle}"/>
                        <TextBlock Grid.Column="2" Text="الوصف" Style="{StaticResource AppEnterpriseTableHeaderTextStyle}"/>
                        <TextBlock Grid.Column="3" Text="النوع" Style="{StaticResource AppEnterpriseTableHeaderTextStyle}"/>
                        <TextBlock Grid.Column="4" Text="المرجع" Style="{StaticResource AppEnterpriseTableHeaderTextStyle}"/>
                        <TextBlock Grid.Column="5" Text="الإجمالي" Style="{StaticResource AppEnterpriseTableHeaderTextStyle}"/>
                        <TextBlock Grid.Column="6" Text="الحالة" Style="{StaticResource AppEnterpriseTableHeaderTextStyle}"/>
                        <TextBlock Grid.Column="7" Text="السطور" Style="{StaticResource AppEnterpriseTableHeaderTextStyle}"/>
                    </Grid>
                </Border>

                <ItemsControl ItemsSource="{Binding RecentEntries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="journals:JournalEntryRowVm">
                            <Border Style="{StaticResource AppEnterpriseDataRowStyle}" Margin="16,0,16,0">
                                <Grid Padding="0,2,0,2" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="105"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{x:Bind EntryNumber}"
                                               Foreground="#2563EB"
                                               FontSize="12.5"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind EntryDateText}"
                                               Foreground="{StaticResource SlateTextBrush}"
                                               FontSize="12"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="2"
                                               Text="{x:Bind Description}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>

                                    <Border Grid.Column="3"
                                            Background="{x:Bind TypeBackgroundBrush}"
                                            CornerRadius="8"
                                            Padding="8,4"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind TypeText}"
                                                   Foreground="{x:Bind TypeForegroundBrush}"
                                                   FontSize="11"
                                                   FontWeight="Medium"/>
                                    </Border>

                                    <TextBlock Grid.Column="4"
                                               Text="{x:Bind ReferenceDisplay}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="5"
                                               Text="{x:Bind TotalDebitText}"
                                               FontSize="12.5"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"/>

                                    <Border Grid.Column="6"
                                            Background="{x:Bind StatusBackgroundBrush}"
                                            CornerRadius="999"
                                            Padding="8,4"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind StatusText}"
                                                   Foreground="{x:Bind StatusForegroundBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                    </Border>

                                    <TextBlock Grid.Column="7"
                                               Text="{x:Bind LineCountText}"
                                               Foreground="{StaticResource SlateTextBrush}"
                                               FontSize="11.5"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
