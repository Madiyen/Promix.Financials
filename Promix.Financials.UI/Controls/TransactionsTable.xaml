<UserControl
    x:Class="Promix.Financials.UI.Controls.TransactionsTable"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:journals="using:Promix.Financials.UI.ViewModels.Journals.Models">

    <Border Background="White" CornerRadius="12" Padding="0" Translation="0,2,0">
        <Border.Shadow>
            <ThemeShadow />
        </Border.Shadow>
        <StackPanel>
            <!-- Table Header Area -->
            <Grid Padding="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock Text="آخر العمليات" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A"/>
                    <TextBlock Text="أحدث السندات والقيود المسجلة مؤخراً." FontSize="13" Foreground="#64748B"/>
                </StackPanel>

                <Border Grid.Column="1" Background="#F1F5F9" CornerRadius="6" Padding="12,6" VerticalAlignment="Center">
                    <TextBlock Text="عرض الكل" FontSize="12" FontWeight="SemiBold" Foreground="#0F172A"/>
                </Border>
            </Grid>

            <!-- Column Labels -->
            <Border Background="#F8FAFC" BorderBrush="#F1F5F9" BorderThickness="0,1" Padding="24,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="رقم السند" FontSize="12" FontWeight="SemiBold" Foreground="#64748B"/>
                    <TextBlock Grid.Column="1" Text="التاريخ" FontSize="12" FontWeight="SemiBold" Foreground="#64748B"/>
                    <TextBlock Grid.Column="2" Text="الوصف" FontSize="12" FontWeight="SemiBold" Foreground="#64748B"/>
                    <TextBlock Grid.Column="3" Text="النوع" FontSize="12" FontWeight="SemiBold" Foreground="#64748B"/>
                    <TextBlock Grid.Column="4" Text="المبلغ" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Column="5" Text="الحالة" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- Table Rows -->
            <ItemsControl ItemsSource="{Binding RecentEntries}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="journals:JournalEntryRowVm">
                        <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="24,16">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{x:Bind EntryNumber}" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                
                                <TextBlock Grid.Column="1" Text="{x:Bind EntryDateText}" FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>
                                
                                <TextBlock Grid.Column="2" Text="{x:Bind Description}" FontSize="13" Foreground="#0F172A" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>

                                <Border Grid.Column="3" Background="{x:Bind TypeBackgroundBrush}" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind TypeText}" Foreground="{x:Bind TypeForegroundBrush}" FontSize="11" FontWeight="Bold"/>
                                </Border>

                                <TextBlock Grid.Column="4" Text="{x:Bind TotalDebitText}" FontSize="13" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Right" VerticalAlignment="Center" Language="en-US"/>

                                <Border Grid.Column="5" Background="{x:Bind StatusBackgroundBrush}" CornerRadius="12" Padding="10,4" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind StatusText}" Foreground="{x:Bind StatusForegroundBrush}" FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            
            <!-- Footer Action -->
            <Border Padding="24" HorizontalAlignment="Center">
                <Button Content="تحميل المزيد من العمليات" Background="Transparent" BorderThickness="0" Foreground="#64748B" FontSize="13" FontWeight="Medium"/>
            </Border>
        </StackPanel>
    </Border>
</UserControl>