<UserControl
    x:Class="Promix.Financials.UI.Controls.TransactionsTable"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:journals="using:Promix.Financials.UI.ViewModels.Journals.Models">

    <Border Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrushStrong}"
            BorderThickness="1"
            CornerRadius="16">
        <StackPanel>
            <Grid Padding="20,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock Text="آخر العمليات" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                    <TextBlock Text="آخر السندات والقيود المسجلة لالتقاط الحالة التشغيلية بسرعة." FontSize="13" Foreground="{StaticResource SecondaryTextBrush}"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{StaticResource CardSubtleBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrushStrong}"
                        BorderThickness="1"
                        CornerRadius="999"
                        Padding="10,4"
                        VerticalAlignment="Center">
                    <TextBlock Text="آخر 6 عمليات" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}"/>
                </Border>
            </Grid>

            <Border Background="{StaticResource CardSubtleBackgroundBrush}" BorderBrush="{StaticResource BorderBrushStrong}" BorderThickness="0,1" Padding="20,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="رقم السند" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}"/>
                    <TextBlock Grid.Column="1" Text="التاريخ" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}"/>
                    <TextBlock Grid.Column="2" Text="الوصف" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}"/>
                    <TextBlock Grid.Column="3" Text="النوع" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}"/>
                    <TextBlock Grid.Column="4" Text="المبلغ" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Column="5" Text="الحالة" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <StackPanel Visibility="{Binding LoadingVisibility}"
                        Spacing="10"
                        Padding="20,18">
                <Border Background="{StaticResource CardSubtleBackgroundBrush}" CornerRadius="10" Height="18"/>
                <Border Background="{StaticResource CardSubtleBackgroundBrush}" CornerRadius="10" Height="18"/>
                <Border Background="{StaticResource CardSubtleBackgroundBrush}" CornerRadius="10" Height="18"/>
            </StackPanel>

            <StackPanel Visibility="{Binding EmptyEntriesVisibility}"
                        Padding="20,28"
                        Spacing="8"
                        HorizontalAlignment="Center">
                <FontIcon Glyph="&#xE14C;" FontSize="28" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="لا توجد عمليات حديثة بعد" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="ستظهر آخر السندات والقيود هنا بمجرد بدء العمل." FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center"/>
            </StackPanel>

            <ItemsControl ItemsSource="{Binding RecentEntries}" Visibility="{Binding RecentEntriesVisibility}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="journals:JournalEntryRowVm">
                        <Border BorderBrush="{StaticResource BorderBrushStrong}" BorderThickness="0,0,0,1" Padding="20,14">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{x:Bind EntryNumber}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                                
                                <TextBlock Grid.Column="1" Text="{x:Bind EntryDateText}" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                
                                <TextBlock Grid.Column="2" Text="{x:Bind Description}" FontSize="13" Foreground="{StaticResource PrimaryTextBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>

                                <Border Grid.Column="3"
                                        Style="{StaticResource SoftBadgeStyle}"
                                        Background="{x:Bind TypeBackgroundBrush}">
                                    <TextBlock Text="{x:Bind TypeText}" Foreground="{x:Bind TypeForegroundBrush}" FontSize="11" FontWeight="SemiBold"/>
                                </Border>

                                <TextBlock Grid.Column="4" Text="{x:Bind TotalDebitText}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Language="en-US"/>

                                <Border Grid.Column="5"
                                        Style="{StaticResource SoftBadgeStyle}"
                                        Background="{x:Bind StatusBackgroundBrush}"
                                        HorizontalAlignment="Right">
                                    <TextBlock Text="{x:Bind StatusText}" Foreground="{x:Bind StatusForegroundBrush}" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Padding="16" HorizontalAlignment="Center">
                <Button Content="عرض القائمة الكاملة"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        FontSize="13"
                        FontWeight="SemiBold"/>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
