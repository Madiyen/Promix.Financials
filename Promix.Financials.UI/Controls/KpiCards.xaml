<UserControl
    x:Class="Promix.Financials.UI.Controls.KpiCards"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource AppMetricCardCompactStyle}" Padding="0">
            <Grid>
                <Border Height="3"
                        VerticalAlignment="Top"
                        Background="{StaticResource SidebarActiveBrush}"
                        CornerRadius="12,12,0,0"/>
                <StackPanel Spacing="12" Padding="16,14,16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="42"
                                Height="42"
                                Background="{StaticResource InfoSurfaceBrush}"
                                CornerRadius="12"
                                HorizontalAlignment="Left">
                            <FontIcon Glyph="&#xE80F;"
                                      Foreground="{StaticResource SidebarActiveBrush}"
                                      FontSize="16"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="1"
                                Style="{StaticResource AppEnterpriseInfoChipStyle}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                            <TextBlock Text="إجمالي"
                                       Style="{StaticResource AppEnterpriseInfoChipTextStyle}"/>
                        </Border>
                    </Grid>

                    <StackPanel Spacing="4">
                        <TextBlock Text="إجمالي السندات" Style="{StaticResource AppMetricLabelTextStyle}"/>
                        <TextBlock Text="{Binding TotalEntriesText}" Style="{StaticResource AppMetricValueCompactTextStyle}"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="{StaticResource BorderBrushSoft}"/>

                    <TextBlock Text="كل القيود والسندات المسجلة حتى الآن"
                               Style="{StaticResource AppSectionCaptionCompactTextStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource AppMetricCardCompactStyle}" Padding="0">
            <Grid>
                <Border Height="3"
                        VerticalAlignment="Top"
                        Background="{StaticResource SuccessBrush}"
                        CornerRadius="12,12,0,0"/>
                <StackPanel Spacing="12" Padding="16,14,16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="42"
                                Height="42"
                                Background="{StaticResource SuccessSurfaceBrush}"
                                CornerRadius="12"
                                HorizontalAlignment="Left">
                            <FontIcon Glyph="&#xE8FB;"
                                      Foreground="{StaticResource SuccessBrush}"
                                      FontSize="16"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="1"
                                Style="{StaticResource AppEnterpriseInfoChipStyle}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                            <TextBlock Text="معتمد"
                                       Style="{StaticResource AppEnterpriseInfoChipTextStyle}"/>
                        </Border>
                    </Grid>

                    <StackPanel Spacing="4">
                        <TextBlock Text="المرحل" Style="{StaticResource AppMetricLabelTextStyle}"/>
                        <TextBlock Text="{Binding PostedEntriesText}" Style="{StaticResource AppMetricValueCompactTextStyle}"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="{StaticResource BorderBrushSoft}"/>

                    <TextBlock Text="سندات مؤثرة على الأرصدة والتقارير"
                               Style="{StaticResource AppSectionCaptionCompactTextStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource AppMetricCardCompactStyle}" Padding="0">
            <Grid>
                <Border Height="3"
                        VerticalAlignment="Top"
                        Background="{StaticResource WarningBrush}"
                        CornerRadius="12,12,0,0"/>
                <StackPanel Spacing="12" Padding="16,14,16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="42"
                                Height="42"
                                Background="{StaticResource WarningSurfaceBrush}"
                                CornerRadius="12"
                                HorizontalAlignment="Left">
                            <FontIcon Glyph="&#xE70F;"
                                      Foreground="{StaticResource WarningBrush}"
                                      FontSize="16"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="1"
                                Style="{StaticResource AppEnterpriseInfoChipStyle}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                            <TextBlock Text="مراجعة"
                                       Style="{StaticResource AppEnterpriseInfoChipTextStyle}"/>
                        </Border>
                    </Grid>

                    <StackPanel Spacing="4">
                        <TextBlock Text="المسودات" Style="{StaticResource AppMetricLabelTextStyle}"/>
                        <TextBlock Text="{Binding DraftEntriesText}" Style="{StaticResource AppMetricValueCompactTextStyle}"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="{StaticResource BorderBrushSoft}"/>

                    <TextBlock Text="سندات بانتظار المراجعة أو الترحيل"
                               Style="{StaticResource AppSectionCaptionCompactTextStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="3" Style="{StaticResource AppMetricCardCompactStyle}" Padding="0">
            <Grid>
                <Border Height="3"
                        VerticalAlignment="Top"
                        Background="{StaticResource DangerBrush}"
                        CornerRadius="12,12,0,0"/>
                <StackPanel Spacing="12" Padding="16,14,16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="42"
                                Height="42"
                                Background="{StaticResource DangerSurfaceBrush}"
                                CornerRadius="12"
                                HorizontalAlignment="Left">
                            <FontIcon Glyph="&#xE81C;"
                                      Foreground="{StaticResource DangerBrush}"
                                      FontSize="16"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="1"
                                Style="{StaticResource AppEnterpriseInfoChipStyle}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                            <TextBlock Text="اليوم"
                                       Style="{StaticResource AppEnterpriseInfoChipTextStyle}"/>
                        </Border>
                    </Grid>

                    <StackPanel Spacing="4">
                        <TextBlock Text="صافي اليوم" Style="{StaticResource AppMetricLabelTextStyle}"/>
                        <TextBlock Text="{Binding TodayNetMovementText}" Style="{StaticResource AppMetricValueCompactTextStyle}"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="{StaticResource BorderBrushSoft}"/>

                    <TextBlock Text="{Binding TodayMovementHintText}"
                               Style="{StaticResource AppSectionCaptionCompactTextStyle}"
                               MaxWidth="220"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
