<UserControl
    x:Class="Promix.Financials.UI.Controls.KpiCards"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid ColumnSpacing="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- KPI: Total Cash / Entries -->
        <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="24" Translation="0,2,0">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <StackPanel Spacing="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="إجمالي السندات" FontSize="14" FontWeight="Medium" Foreground="#64748B"/>
                    <Border Grid.Column="1" Background="#F1F5F9" CornerRadius="6" Padding="8,4">
                        <FontIcon Glyph="&#xE80F;" FontSize="14" Foreground="#0F172A"/>
                    </Border>
                </Grid>
                
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding TotalEntriesText}" FontSize="28" FontWeight="SemiBold" Foreground="#0F172A" Language="en-US"/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Border Background="#DCFCE7" CornerRadius="4" Padding="6,2">
                            <TextBlock Text="+2.5%" FontSize="11" FontWeight="Bold" Foreground="#166534"/>
                        </Border>
                        <TextBlock Text="منذ الشهر الماضي" FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- KPI: Posted Entries -->
        <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="24" Translation="0,2,0">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <StackPanel Spacing="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="المرحل معتمداً" FontSize="14" FontWeight="Medium" Foreground="#64748B"/>
                    <Border Grid.Column="1" Background="#DCFCE7" CornerRadius="6" Padding="8,4">
                        <FontIcon Glyph="&#xE8FB;" FontSize="14" Foreground="#166534"/>
                    </Border>
                </Grid>
                
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding PostedEntriesText}" FontSize="28" FontWeight="SemiBold" Foreground="#0F172A" Language="en-US"/>
                    <TextBlock Text="سندات مؤثرة مالياً" FontSize="12" Foreground="#64748B"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- KPI: Drafts -->
        <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="24" Translation="0,2,0">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <StackPanel Spacing="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="المسودات قيد المراجعة" FontSize="14" FontWeight="Medium" Foreground="#64748B"/>
                    <Border Grid.Column="1" Background="#FEF3C7" CornerRadius="6" Padding="8,4">
                        <FontIcon Glyph="&#xE70F;" FontSize="14" Foreground="#92400E"/>
                    </Border>
                </Grid>
                
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding DraftEntriesText}" FontSize="28" FontWeight="SemiBold" Foreground="#0F172A" Language="en-US"/>
                    <TextBlock Text="بانتظار الاعتماد النهائي" FontSize="12" Foreground="#64748B"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- KPI: Daily Net -->
        <Border Grid.Column="3" Background="White" CornerRadius="12" Padding="24" Translation="0,2,0">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <StackPanel Spacing="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="صافي حركة اليوم" FontSize="14" FontWeight="Medium" Foreground="#64748B"/>
                    <Border Grid.Column="1" Background="#E0E7FF" CornerRadius="6" Padding="8,4">
                        <FontIcon Glyph="&#xE81C;" FontSize="14" Foreground="#3730A3"/>
                    </Border>
                </Grid>
                
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding TodayNetMovementText}" FontSize="28" FontWeight="SemiBold" Foreground="#0F172A" Language="en-US"/>
                    <TextBlock Text="تحديث لحظي للبيانات" FontSize="12" Foreground="#64748B"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>