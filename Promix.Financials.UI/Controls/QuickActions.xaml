<UserControl
    x:Class="Promix.Financials.UI.Controls.QuickActions"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="DashboardActionTileButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource AppSurfaceCardCompactStyle}"
            Padding="16">
        <StackPanel Spacing="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="3">
                    <TextBlock Text="إجراءات سريعة" Style="{StaticResource AppSectionTitleTextStyle}"/>
                    <TextBlock Text="اختصارات تشغيلية مباشرة من الشاشة الرئيسية."
                               Style="{StaticResource AppSectionCaptionCompactTextStyle}"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Style="{StaticResource AppEnterpriseInfoChipStyle}"
                        VerticalAlignment="Center">
                    <TextBlock Text="اختصارات"
                               Style="{StaticResource AppEnterpriseInfoChipTextStyle}"/>
                </Border>
            </Grid>

            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Click="ReceiptVoucher_Click"
                        Style="{StaticResource DashboardActionTileButtonStyle}">
                    <Border Background="#1E3A5F"
                            CornerRadius="12"
                            Padding="14,12">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" Background="#2B4C74" CornerRadius="10">
                                <FontIcon Glyph="&#xE8C7;" Foreground="White" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="0" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="سند قبض" Foreground="White" FontSize="12.5" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Button>

                <Button Grid.Column="1"
                        Click="PaymentVoucher_Click"
                        Style="{StaticResource DashboardActionTileButtonStyle}">
                    <Border Style="{StaticResource AppEnterpriseInnerCardStyle}" Padding="14,12">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" Background="#FEE2E2" CornerRadius="10">
                                <FontIcon Glyph="&#xEAFD;" Foreground="{StaticResource DangerBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="0" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="سند صرف" Foreground="{StaticResource PrimaryTextBrush}" FontSize="12.5" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Button>

                <Button Grid.Column="2"
                        Click="TransferVoucher_Click"
                        Style="{StaticResource DashboardActionTileButtonStyle}">
                    <Border Style="{StaticResource AppEnterpriseInnerCardStyle}" Padding="14,12">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" Background="#E0E7FF" CornerRadius="10">
                                <FontIcon Glyph="&#xE8AB;" Foreground="#4F46E5" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="0" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="تحويل" Foreground="{StaticResource PrimaryTextBrush}" FontSize="12.5" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Button>

                <Button Grid.Column="3"
                        Click="DailyJournal_Click"
                        Style="{StaticResource DashboardActionTileButtonStyle}">
                    <Border Style="{StaticResource AppEnterpriseInnerCardStyle}" Padding="14,12">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" Background="#EDE9FE" CornerRadius="10">
                                <FontIcon Glyph="&#xE8A5;" Foreground="#7C3AED" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="0" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="قيد يومية" Foreground="{StaticResource PrimaryTextBrush}" FontSize="12.5" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Button>

                <Button Grid.Column="4"
                        Click="Accounts_Click"
                        Style="{StaticResource DashboardActionTileButtonStyle}">
                    <Border Style="{StaticResource AppEnterpriseInnerCardStyle}" Padding="14,12">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" Background="#FEF3C7" CornerRadius="10">
                                <FontIcon Glyph="&#xE8D4;" Foreground="{StaticResource WarningBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="0" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="الحسابات" Foreground="{StaticResource PrimaryTextBrush}" FontSize="12.5" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Button>

                <Button Grid.Column="5"
                        Click="Reports_Click"
                        Style="{StaticResource DashboardActionTileButtonStyle}">
                    <Border Style="{StaticResource AppEnterpriseInnerCardStyle}" Padding="14,12">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" Background="#CFFAFE" CornerRadius="10">
                                <FontIcon Glyph="&#xE9D2;" Foreground="#0891B2" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="0" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="التقارير" Foreground="{StaticResource PrimaryTextBrush}" FontSize="12.5" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
