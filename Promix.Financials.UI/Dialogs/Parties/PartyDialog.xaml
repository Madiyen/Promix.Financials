<ContentDialog
    x:Class="Promix.Financials.UI.Dialogs.Parties.PartyDialog"
    x:Name="RootDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    FlowDirection="RightToLeft"
    Background="Transparent"
    FullSizeDesired="True"
    HorizontalContentAlignment="Stretch"
    VerticalContentAlignment="Stretch"
    Title="">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">860</x:Double>
        <x:Double x:Key="ContentDialogMinWidth">780</x:Double>
    </ContentDialog.Resources>

    <Grid Width="820" MaxWidth="860" MaxHeight="700" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="20" Padding="18" MinHeight="126">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1E3A5F" Offset="0"/>
                    <GradientStop Color="#1D4ED8" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="52" Height="52" Background="#166534" CornerRadius="16">
                            <FontIcon Glyph="&#xE716;"
                                      Foreground="White"
                                      FontSize="24"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="4">
                            <Border Background="#1E40AF" CornerRadius="12" Padding="10,4" HorizontalAlignment="Right">
                                <TextBlock x:Name="DialogBadgeText"
                                           Text="إضافة"
                                           Style="{StaticResource VoucherDialogBadgeTextStyle}"
                                           Foreground="White"/>
                            </Border>
                            <TextBlock x:Name="DialogTitleText"
                                       Text="إضافة طرف"
                                       Foreground="White"
                                       FontSize="23"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock x:Name="DialogSubtitleText"
                               Text="أنشئ عميلاً أو مورداً جديداً، وسيقوم النظام بإنشاء حساباته المرتبطة تلقائياً داخل شجرة الحسابات."
                               Foreground="#DBEAFE"
                               FontSize="12"
                               TextWrapping="WrapWholeWords"
                               MaxWidth="520"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#140B1220"
                        BorderBrush="#2ADBEAFE"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="14">
                    <StackPanel Spacing="6">
                        <TextBlock Text="ملخص الطرف" Foreground="#BFDBFE" FontSize="10.5"/>
                        <TextBlock x:Name="SummaryNameText"
                                   Text="اسم الطرف سيظهر هنا"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   TextWrapping="WrapWholeWords"/>
                        <TextBlock x:Name="SummaryCodeText"
                                   Text="سيُولد الكود تلقائياً"
                                   Foreground="#DBEAFE"
                                   FontSize="12"/>
                        <TextBlock x:Name="SummaryTypeText"
                                   Text="النوع: عميل"
                                   Foreground="White"
                                   FontSize="12.5"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="SummaryAccountText"
                                   Text="الحساب: لم يتم اختيار حساب بعد"
                                   Foreground="#E0F2FE"
                                   FontSize="11.5"
                                   TextWrapping="WrapWholeWords"/>
                        <TextBlock x:Name="SummaryStatusText"
                                   Text="الحالة: نشط عند الإنشاء"
                                   Foreground="#BFDBFE"
                                   FontSize="11.5"/>
                        <TextBlock x:Name="SummaryBalancesText"
                                   Text="سيُنشئ النظام الحسابات المرتبطة بالطرف تلقائياً داخل شجرة الحسابات."
                                   Foreground="#E0F2FE"
                                   FontSize="11.5"
                                   TextWrapping="WrapWholeWords"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="12">
                <Border Style="{StaticResource VoucherDialogCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="تعريف الطرف" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="الكود" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="CodeTextBox"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         TextChanged="CodeTextBox_TextChanged"
                                         PlaceholderText="يُترك فارغًا للتوليد التلقائي"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="نوع الطرف" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox x:Name="TypeComboBox"
                                          Style="{StaticResource InputComboBoxStyle}"
                                          SelectedIndex="0"
                                          SelectionChanged="TypeComboBox_SelectionChanged">
                                    <ComboBoxItem Content="عميل"/>
                                    <ComboBoxItem Content="مورد"/>
                                    <ComboBoxItem Content="عميل ومورد"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="الاسم العربي" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="NameArTextBox"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         TextChanged="NameArTextBox_TextChanged"
                                         PlaceholderText="مطلوب"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="الاسم الإنكليزي" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="NameEnTextBox"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         PlaceholderText="اختياري"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource VoucherDialogCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="الحسابات المرتبطة" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>

                        <Border x:Name="SubledgerInfoPanel"
                                Background="#EFF6FF"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14,12">
                            <StackPanel Spacing="6">
                                <TextBlock Text="إنشاء تلقائي للحسابات"
                                           Foreground="#1D4ED8"
                                           FontWeight="Bold"/>
                                <TextBlock x:Name="SubledgerInfoText"
                                           Text="عند إنشاء الطرف الجديد، سيولد النظام حساباً أو حسابين مرتبطين به تلقائياً داخل الشجرة الافتراضية حسب نوع الطرف."
                                           Style="{StaticResource HintLabelStyle}"
                                           TextWrapping="WrapWholeWords"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="LegacyAccountsPanel"
                                Background="#FFF7ED"
                                BorderBrush="#FDBA74"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14,12"
                                Visibility="Collapsed">
                            <StackPanel Spacing="6">
                                <TextBlock Text="حسابات تاريخية"
                                           Foreground="#C2410C"
                                           FontWeight="Bold"/>
                                <TextBlock x:Name="LegacyAccountText"
                                           Text="سيظهر هنا الربط القديم للحسابات."
                                           Style="{StaticResource HintLabelStyle}"
                                           TextWrapping="WrapWholeWords"/>
                            </StackPanel>
                        </Border>

                        <TextBlock x:Name="AccountLinkHintText"
                                   Style="{StaticResource HintLabelStyle}"
                                   TextWrapping="WrapWholeWords"
                                   Text="تظهر هنا طريقة إنشاء أو ربط الحسابات الخاصة بالطرف، وتُستخدم هذه الحسابات مباشرة عند اختيار الطرف في السندات والقيود."/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource VoucherDialogCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="بيانات التواصل" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="الهاتف" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="PhoneTextBox"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         PlaceholderText="اختياري"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="الموبايل" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="MobileTextBox"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         PlaceholderText="اختياري"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="البريد الإلكتروني" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="EmailTextBox"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         PlaceholderText="name@example.com"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="الرقم الضريبي" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="TaxNoTextBox"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         PlaceholderText="اختياري"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource VoucherDialogCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="بيانات إضافية" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>

                        <StackPanel Spacing="4">
                            <TextBlock Text="العنوان" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="AddressTextBox"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     PlaceholderText="اختياري"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="ملاحظات" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="NotesTextBox"
                                     Style="{StaticResource MultilineTextBoxStyle}"
                                     Height="96"
                                     TextWrapping="Wrap"
                                     PlaceholderText="أي ملاحظات داخلية على الطرف"/>
                        </StackPanel>

                        <StackPanel x:Name="ActivePanel" Spacing="4">
                            <TextBlock Text="الحالة" Style="{StaticResource FieldLabelStyle}"/>
                            <ToggleSwitch x:Name="ActiveToggleSwitch"
                                          Style="{StaticResource InputToggleSwitchStyle}"
                                          IsOn="True"
                                          Toggled="ActiveToggleSwitch_Toggled"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border x:Name="ValidationBanner"
                Grid.Row="2"
                Style="{StaticResource InlineErrorBannerStyle}"
                Visibility="Collapsed">
            <TextBlock x:Name="ValidationText"
                       Style="{StaticResource ErrorLabelStyle}"
                       TextWrapping="WrapWholeWords"/>
        </Border>

        <Border Grid.Row="3"
                Background="White"
                BorderBrush="#DCE4EE"
                BorderThickness="1"
                CornerRadius="18"
                Padding="14">
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="سيحفظ الطرف ببياناته، ثم ينشئ النظام الحسابات المرتبطة به تلقائياً وفق نوعه داخل شجرة الحسابات."
                           x:Name="FooterHintText"
                           VerticalAlignment="Center"
                           Style="{StaticResource VoucherDialogHintTextStyle}"/>

                <Button Grid.Column="1"
                        Content="إلغاء"
                        Click="CancelButton_Click"
                        Style="{StaticResource SecondaryActionButtonStyle}"/>

                <Button Grid.Column="2"
                        Content="حفظ الطرف"
                        Click="SaveButton_Click"
                        Style="{StaticResource PrimaryActionButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</ContentDialog>
