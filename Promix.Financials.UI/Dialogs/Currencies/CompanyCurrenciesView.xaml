<Page
    x:Class="Promix.Financials.UI.Views.Currencies.CompanyCurrenciesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Promix.Financials.UI.ViewModels.Currencies.Models"
    Background="{StaticResource AppBackgroundBrush}"
    FlowDirection="RightToLeft">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border Width="40" Height="40"
                            Background="#2563EB"
                            CornerRadius="12">
                        <FontIcon Glyph="&#xE8EE;"
                                  FontSize="20"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="عملات الشركة"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="إدارة العملات وأسعار التعادل"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="10"
                        VerticalAlignment="Center">
                <Button Content="↻ تحديث"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        Command="{Binding RefreshCommand}"/>
                <Button x:Name="AddButton"
                        Content="+ إضافة عملة"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        Click="AddButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- ── KPI Cards ── -->
        <Grid Grid.Row="1" Margin="0,0,0,20" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- إجمالي العملات -->
            <Border Grid.Column="0"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="18,14">
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Width="44" Height="44"
                            Background="#EFF6FF"
                            CornerRadius="12">
                        <FontIcon Glyph="&#xE8EE;" FontSize="20" Foreground="#2563EB"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="إجمالي العملات"
                                   FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding TotalCurrenciesText}"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Language="en-US"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- العملات الفعّالة -->
            <Border Grid.Column="1"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="18,14">
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Width="44" Height="44"
                            Background="#F0FDF4"
                            CornerRadius="12">
                        <FontIcon Glyph="&#xE73E;" FontSize="20" Foreground="#16A34A"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="العملات الفعّالة"
                                   FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding ActiveCurrenciesText}"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="#16A34A"
                                   Language="en-US"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- العملة الرئيسية -->
            <Border Grid.Column="2"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="18,14">
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Width="44" Height="44"
                            Background="#FFFBEB"
                            CornerRadius="12">
                        <FontIcon Glyph="&#xE734;" FontSize="20" Foreground="#D97706"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="العملة الرئيسية"
                                   FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding BaseCurrencyText}"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="#D97706"
                                   Language="en-US"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Alerts ── -->
        <StackPanel Grid.Row="2" Spacing="8" Margin="0,0,0,12">
            <Border x:Name="ErrorBanner"
                    Background="#FEF2F2"
                    BorderBrush="#FECACA"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14,10"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xEA39;" FontSize="14" Foreground="#DC2626"/>
                    <TextBlock x:Name="ErrorBannerText"
                               Foreground="#DC2626"
                               FontSize="13"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border x:Name="SuccessBanner"
                    Background="#F0FDF4"
                    BorderBrush="#BBF7D0"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14,10"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE73E;" FontSize="14" Foreground="#16A34A"/>
                    <TextBlock x:Name="SuccessBannerText"
                               Foreground="#16A34A"
                               FontSize="13"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ── DataGrid ── -->
        <Border Grid.Row="3"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Table Header -->
                <Border Grid.Row="0"
                        Background="#F8FAFC"
                        CornerRadius="16,16,0,0"
                        Padding="16,12"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="الكود" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SlateTextBrush}"/>
                        <TextBlock Grid.Column="1" Text="الاسم العربي" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SlateTextBrush}"/>
                        <TextBlock Grid.Column="2" Text="الاسم الإنكليزي" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SlateTextBrush}"/>
                        <TextBlock Grid.Column="3" Text="الرمز" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SlateTextBrush}"/>
                        <TextBlock Grid.Column="4" Text="سعر التعادل" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SlateTextBrush}"/>
                        <TextBlock Grid.Column="5" Text="رئيسية" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SlateTextBrush}"/>
                        <TextBlock Grid.Column="6" Text="الحالة" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SlateTextBrush}"/>
                        <TextBlock Grid.Column="7" Text="الإجراءات" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SlateTextBrush}" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Rows -->
                <ListView Grid.Row="1"
                          x:Name="CurrenciesListView"
                          ItemsSource="{Binding Currencies}"
                          SelectedItem="{Binding SelectedCurrency, Mode=TwoWay}"
                          SelectionMode="Single"
                          Background="Transparent"
                          BorderThickness="0">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="16,10"/>
                            <Setter Property="BorderBrush" Value="#F1F5F9"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="CornerRadius" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:CompanyCurrencyRowVm">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>

                                <!-- الكود -->
                                <Border Grid.Column="0"
                                        Background="#EFF6FF"
                                        CornerRadius="6"
                                        Padding="8,4"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{x:Bind CurrencyCode}"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="#2563EB"
                                               Language="en-US"/>
                                </Border>

                                <!-- الاسم العربي -->
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind NameAr}"
                                           FontSize="13"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           VerticalAlignment="Center"/>

                                <!-- الاسم الإنكليزي -->
                                <TextBlock Grid.Column="2"
                                           Text="{x:Bind NameEn}"
                                           FontSize="13"
                                           Foreground="{StaticResource SlateTextBrush}"
                                           Language="en-US"
                                           VerticalAlignment="Center"/>

                                <!-- الرمز -->
                                <TextBlock Grid.Column="3"
                                           Text="{x:Bind Symbol}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource SlateTextBrush}"
                                           Language="en-US"
                                           VerticalAlignment="Center"/>

                                <!-- سعر التعادل -->
                                <TextBlock Grid.Column="4"
                                           Text="{x:Bind ExchangeRateText}"
                                           FontSize="13"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           Language="en-US"
                                           VerticalAlignment="Center"/>

                                <!-- رئيسية -->
                                <Border Grid.Column="5"
                                        CornerRadius="6"
                                        Padding="8,4"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{x:Bind BaseCurrencyText}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="#D97706"/>
                                </Border>

                                <!-- الحالة -->
                                <Border Grid.Column="6"
                                        CornerRadius="20"
                                        Padding="10,4"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#F0FDF4"/>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{x:Bind StatusText}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="#16A34A"/>
                                </Border>

                                <!-- الإجراءات -->
                                <StackPanel Grid.Column="7"
                                            Orientation="Horizontal"
                                            Spacing="6"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <Button x:Name="EditRowButton"
                                            Content="✎ تعديل"
                                            Tag="{x:Bind Id}"
                                            Style="{StaticResource SecondaryActionButtonStyle}"
                                            FontSize="11"
                                            Padding="8,4"
                                            MinHeight="30"
                                            Click="EditRowButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- ── Footer: زر إيقاف ── -->
        <Border Grid.Row="4"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16,10"
                Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           x:Name="SelectionHintText"
                           Text="اختر عملة من القائمة لتنفيذ إجراء عليها"
                           FontSize="12"
                           Foreground="{StaticResource MutedTextBrush}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        x:Name="DeactivateButton"
                        Content="⊘ إيقاف العملة"
                        IsEnabled="{Binding CanDeactivate}"
                        Background="#FEF2F2"
                        Foreground="#DC2626"
                        BorderBrush="#FECACA"
                        BorderThickness="1"
                        Padding="14,8"
                        MinHeight="40"
                        CornerRadius="10"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Click="DeactivateButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Page>