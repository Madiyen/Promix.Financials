<ContentDialog
    x:Class="Promix.Financials.UI.Dialogs.Journals.DailyCashClosingDialog"
    x:Name="RootDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Promix.Financials.UI.Controls.Journals"
    Title=""
    PrimaryButtonText="إنشاء وترحيل"
    CloseButtonText="إلغاء"
    DefaultButton="Primary"
    FlowDirection="RightToLeft"
    FullSizeDesired="True"
    HorizontalContentAlignment="Stretch"
    VerticalContentAlignment="Stretch">

    <Grid MaxWidth="720" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="24" Padding="18" MinHeight="112">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0C4A6E" Offset="0"/>
                    <GradientStop Color="#0369A1" Offset="0.55"/>
                    <GradientStop Color="#38BDF8" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="88"/>
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="6">
                    <TextBlock Text="إقفال صندوق يومي" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="{Binding HintText}" Foreground="#E0F2FE" TextWrapping="WrapWholeWords"/>
                    <TextBlock Text="Ctrl+Enter لإنشاء السند مباشرة بعد اكتمال البيانات."
                               Foreground="White"
                               FontSize="11"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Width="76"
                        Height="76"
                        CornerRadius="38"
                        Background="#075985"
                        HorizontalAlignment="Right">
                    <FontIcon Glyph="&#xE8D4;"
                              Foreground="White"
                              FontSize="30"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="18" Padding="18">
            <StackPanel Spacing="12">
                <TextBlock Text="إعداد الإقفال" FontSize="17" FontWeight="Bold"/>

                <controls:AccountLookupBox Header="الحساب المطلوب تصفيره"
                                           PlaceholderText="مثال: الصندوق"
                                           ItemsSource="{Binding AccountOptions}"
                                           SelectedAccountId="{Binding SelectedSourceAccountId, Mode=TwoWay}"/>

                <controls:AccountLookupBox Header="الحساب المقابل"
                                           PlaceholderText="مثال: الأموال الجاهزة"
                                           ItemsSource="{Binding AccountOptions}"
                                           SelectedAccountId="{Binding SelectedTargetAccountId, Mode=TwoWay}"/>

                <StackPanel Spacing="6">
                    <TextBlock Text="التاريخ" Style="{StaticResource FieldLabelStyle}"/>
                    <DatePicker Style="{StaticResource InputDatePickerStyle}"
                                Date="{Binding EntryDate, Mode=TwoWay}"/>
                </StackPanel>

                <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="14,12">
                    <StackPanel Spacing="8">
                        <CheckBox Content="إقفال الفترة حتى هذا التاريخ"
                                  IsChecked="{Binding LockThroughEntryDate, Mode=TwoWay}"/>
                        <TextBlock Text="{Binding LockPeriodHintText}"
                                   Foreground="{StaticResource SlateTextBrush}"
                                   FontSize="12"
                                   TextWrapping="WrapWholeWords"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="18" Padding="18">
            <StackPanel Spacing="12">
                <TextBlock Text="ملاحظات الإقفال" FontSize="17" FontWeight="Bold"/>

                <StackPanel Spacing="6">
                    <TextBlock Text="رقم مرجعي" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Style="{StaticResource InputTextBoxStyle}"
                             Text="{Binding ReferenceNo, Mode=TwoWay}"
                             PlaceholderText="اختياري"/>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="البيان" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Style="{StaticResource MultilineTextBoxStyle}"
                             Text="{Binding Description, Mode=TwoWay}"
                             Height="100"
                             PlaceholderText="اتركه فارغاً ليولّد النظام وصفاً تلقائياً واضحاً"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="3"
                x:Name="ErrorBanner"
                Background="#FEF2F2"
                BorderBrush="#FECACA"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14,12"
                Visibility="Collapsed">
            <TextBlock x:Name="ErrorText" Foreground="#DC2626" TextWrapping="WrapWholeWords"/>
        </Border>
    </Grid>
</ContentDialog>
