<ContentDialog
    x:Class="Promix.Financials.UI.Dialogs.Journals.TransferVoucherDialog"
    x:Name="RootDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Promix.Financials.UI.Controls.Journals"
    Title=""
    FlowDirection="RightToLeft"
    RequestedTheme="Light"
    Background="Transparent"
    FullSizeDesired="True"
    HorizontalContentAlignment="Stretch"
    VerticalContentAlignment="Stretch">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">900</x:Double>
        <x:Double x:Key="ContentDialogMinWidth">820</x:Double>
    </ContentDialog.Resources>

    <Grid Width="820" MaxWidth="860" MaxHeight="690" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource VoucherDialogHeaderCardStyle}">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Spacing="6"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Background="#EEF2FF"
                                CornerRadius="999"
                                Padding="10,4">
                            <TextBlock Text="{Binding EffectBadgeText}"
                                       Foreground="#4338CA"
                                       Style="{StaticResource VoucherDialogBadgeTextStyle}"/>
                        </Border>

                        <Border Background="#EFF6FF"
                                CornerRadius="999"
                                Padding="10,4">
                            <TextBlock Text="{Binding EntryMetaText}"
                                       Foreground="#2563EB"
                                       Style="{StaticResource VoucherDialogBadgeTextStyle}"/>
                        </Border>
                    </StackPanel>

                    <TextBlock Text="{Binding Title}"
                               Style="{StaticResource AppSectionTitleTextStyle}"/>
                    <TextBlock Text="اختر المصدر والمستلم ثم العملة والمبلغ، وسيتكون القيد الناتج ومعاينة الأثر مباشرة."
                               Style="{StaticResource VoucherDialogSubtleTextStyle}"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Style="{StaticResource VoucherDialogCompactStripStyle}"
                        Background="#EEF2FF">
                    <StackPanel Spacing="2">
                        <TextBlock Text="المكافئ"
                                   Style="{StaticResource VoucherDialogMetricLabelStyle}"/>
                        <TextBlock Text="{Binding EquivalentAmountText}"
                                   Style="{StaticResource VoucherDialogMetricValueStyle}"
                                   Foreground="#4338CA"
                                   Language="en-US"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource VoucherDialogCompactStripStyle}">
                    <StackPanel Spacing="2">
                        <TextBlock Text="الأثر"
                                   Style="{StaticResource VoucherDialogMetricLabelStyle}"/>
                        <TextBlock Text="تحويل مزدوج"
                                   Style="{StaticResource VoucherDialogMetricValueStyle}"
                                   FontSize="14"
                                   Foreground="#0F172A"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      ZoomMode="Disabled">
            <StackPanel Spacing="12">
                <Border Style="{StaticResource VoucherDialogCardStyle}">
                    <StackPanel Spacing="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="3">
                                <TextBlock Text="بيانات التحويل" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>
                                <TextBlock Text="المصدر والمستلم أولًا ثم العملة والمبلغ."
                                           Style="{StaticResource VoucherDialogSubtleTextStyle}"/>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Background="#EEF2FF"
                                    BorderBrush="#C7D2FE"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10,5"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding EffectBadgeText}"
                                           Foreground="#3730A3"
                                           Style="{StaticResource VoucherDialogBadgeTextStyle}"/>
                            </Border>
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="التاريخ" Style="{StaticResource FieldLabelStyle}"/>
                                <DatePicker Style="{StaticResource InputDatePickerStyle}"
                                            Date="{Binding EntryDate, Mode=TwoWay}"
                                            IsEnabled="{Binding IsEditing}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="الرقم المرجعي" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Style="{StaticResource InputTextBoxStyle}"
                                         Text="{Binding ReferenceNo, Mode=TwoWay}"
                                         IsEnabled="{Binding IsEditing}"
                                         PlaceholderText="اختياري"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="White"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="12"
                                    Padding="12">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="جهة المصدر" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="نوع الجهة" Style="{StaticResource FieldLabelStyle}"/>
                                        <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                                  SelectedIndex="{Binding SourceEndpoint.ModeIndex, Mode=TwoWay}"
                                                  IsEnabled="{Binding IsEditing}">
                                            <ComboBoxItem Content="حساب عام"/>
                                            <ComboBoxItem Content="طرف"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Spacing="4"
                                                Visibility="{Binding SourceEndpoint.GeneralAccountVisibility}">
                                        <controls:AccountLookupBox Header="الحساب العام"
                                                                   PlaceholderText="اختر الحساب المصدر"
                                                                   ItemsSource="{Binding GeneralTransferAccountOptions}"
                                                                   SelectedAccountId="{Binding SourceEndpoint.SelectedAccountId, Mode=TwoWay}"
                                                                   IsEnabled="{Binding IsEditing}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="4"
                                                Visibility="{Binding SourceEndpoint.PartyPickerVisibility}">
                                        <TextBlock Text="الطرف" Style="{StaticResource FieldLabelStyle}"/>
                                        <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                                  ItemsSource="{Binding PartyOptions}"
                                                  DisplayMemberPath="DisplayText"
                                                  SelectedValuePath="Id"
                                                  SelectedValue="{Binding SourceEndpoint.SelectedPartyId, Mode=TwoWay}"
                                                  IsEnabled="{Binding IsEditing}"
                                                  PlaceholderText="اختر الطرف"/>
                                    </StackPanel>

                                    <StackPanel Spacing="4"
                                                Visibility="{Binding SourceEndpoint.PartySideVisibility}">
                                        <TextBlock Text="جهة الطرف" Style="{StaticResource FieldLabelStyle}"/>
                                        <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                                  SelectedIndex="{Binding SourceEndpoint.PartySideIndex, Mode=TwoWay}"
                                                  IsEnabled="{Binding IsEditing}">
                                            <ComboBoxItem Content="عميل"/>
                                            <ComboBoxItem Content="مورد"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Spacing="4"
                                                Visibility="{Binding SourceEndpoint.ResolvedAccountVisibility}">
                                        <TextBlock Text="الحساب الناتج" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                                 Text="{Binding SourceEndpoint.ResolvedAccountText}"
                                                 IsReadOnly="True"
                                                 IsTabStop="False"/>
                                    </StackPanel>

                                    <TextBlock Text="{Binding SourceGuideText}"
                                               Style="{StaticResource VoucherDialogHintTextStyle}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Background="White"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="12"
                                    Padding="12">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="الجهة المستلمة" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="نوع الجهة" Style="{StaticResource FieldLabelStyle}"/>
                                        <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                                  SelectedIndex="{Binding TargetEndpoint.ModeIndex, Mode=TwoWay}"
                                                  IsEnabled="{Binding IsEditing}">
                                            <ComboBoxItem Content="حساب عام"/>
                                            <ComboBoxItem Content="طرف"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Spacing="4"
                                                Visibility="{Binding TargetEndpoint.GeneralAccountVisibility}">
                                        <controls:AccountLookupBox Header="الحساب العام"
                                                                   PlaceholderText="اختر الجهة المستلمة"
                                                                   ItemsSource="{Binding GeneralTransferAccountOptions}"
                                                                   SelectedAccountId="{Binding TargetEndpoint.SelectedAccountId, Mode=TwoWay}"
                                                                   IsEnabled="{Binding IsEditing}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="4"
                                                Visibility="{Binding TargetEndpoint.PartyPickerVisibility}">
                                        <TextBlock Text="الطرف" Style="{StaticResource FieldLabelStyle}"/>
                                        <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                                  ItemsSource="{Binding PartyOptions}"
                                                  DisplayMemberPath="DisplayText"
                                                  SelectedValuePath="Id"
                                                  SelectedValue="{Binding TargetEndpoint.SelectedPartyId, Mode=TwoWay}"
                                                  IsEnabled="{Binding IsEditing}"
                                                  PlaceholderText="اختر الطرف"/>
                                    </StackPanel>

                                    <StackPanel Spacing="4"
                                                Visibility="{Binding TargetEndpoint.PartySideVisibility}">
                                        <TextBlock Text="جهة الطرف" Style="{StaticResource FieldLabelStyle}"/>
                                        <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                                  SelectedIndex="{Binding TargetEndpoint.PartySideIndex, Mode=TwoWay}"
                                                  IsEnabled="{Binding IsEditing}">
                                            <ComboBoxItem Content="عميل"/>
                                            <ComboBoxItem Content="مورد"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Spacing="4"
                                                Visibility="{Binding TargetEndpoint.ResolvedAccountVisibility}">
                                        <TextBlock Text="الحساب الناتج" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                                 Text="{Binding TargetEndpoint.ResolvedAccountText}"
                                                 IsReadOnly="True"
                                                 IsTabStop="False"/>
                                    </StackPanel>

                                    <TextBlock Text="{Binding TargetGuideText}"
                                               Style="{StaticResource VoucherDialogHintTextStyle}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="العملة" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                          ItemsSource="{Binding CurrencyOptions}"
                                          DisplayMemberPath="DisplayText"
                                          SelectedValuePath="CurrencyCode"
                                          SelectedValue="{Binding SelectedCurrencyCode, Mode=TwoWay}"
                                          IsEnabled="{Binding IsEditing}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="المبلغ بالعملة" Style="{StaticResource FieldLabelStyle}"/>
                                <NumberBox Style="{StaticResource InputNumberBoxStyle}"
                                           Value="{Binding Amount, Mode=TwoWay}"
                                           IsEnabled="{Binding IsEditing}"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="سعر الصرف" Style="{StaticResource FieldLabelStyle}"/>
                                <NumberBox Style="{StaticResource InputNumberBoxStyle}"
                                           Value="{Binding ExchangeRate, Mode=TwoWay}"
                                           IsEnabled="{Binding CanEditExchangeRate}"/>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Background="#EEF2FF"
                                    BorderBrush="#C7D2FE"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="12,10"
                                    VerticalAlignment="Bottom">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="&#xE8AB;"
                                              Foreground="#4338CA"
                                              FontSize="16"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="قيمة التحويل المكافئة"
                                               Foreground="#3730A3"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding EquivalentAmountText}"
                                               Foreground="#4338CA"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Language="en-US"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <StackPanel Spacing="4">
                            <TextBlock Text="البيان" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Style="{StaticResource MultilineTextBoxStyle}"
                                     Text="{Binding Description, Mode=TwoWay}"
                                     IsEnabled="{Binding IsEditing}"
                                     Height="76"
                                     PlaceholderText="اكتب سبب التحويل بين الحسابين"/>
                            <TextBlock Text="{Binding DescriptionGuideText}"
                                       Style="{StaticResource VoucherDialogHintTextStyle}"/>
                        </StackPanel>

                        <Border Background="White"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="12"
                                Padding="12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="التسويات" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>
                                <TextBlock Text="حدّد هل تريد من النظام إعادة بناء تسويات الأطراف تلقائيًا بعد ترحيل هذا السند."
                                           Style="{StaticResource VoucherDialogSubtleTextStyle}"/>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="وضع التسوية" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                              SelectedIndex="{Binding SettlementModeIndex, Mode=TwoWay}"
                                              IsEnabled="{Binding IsEditing}">
                                        <ComboBoxItem Content="بدون تسوية تلقائية"/>
                                        <ComboBoxItem Content="إجراء تسوية تلقائية"/>
                                    </ComboBox>
                                </StackPanel>

                                <TextBlock Text="{Binding SettlementModeHintText}"
                                           Style="{StaticResource VoucherDialogHintTextStyle}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource VoucherDialogCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="معاينة القيد" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>
                        <TextBlock Text="{Binding PreviewNoteText}" Style="{StaticResource VoucherDialogSubtleTextStyle}"/>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock Text="القيد الناتج" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>

                                <Border Style="{StaticResource VoucherDialogInfoCardStyle}"
                                        Visibility="{Binding PostingPreviewPlaceholderVisibility}">
                                    <TextBlock Text="ستظهر أسطر قيد التحويل هنا فور اكتمال اختيار الحسابين وإدخال مبلغ صالح."
                                               Style="{StaticResource VoucherDialogHintTextStyle}"/>
                                </Border>

                                <ItemsControl ItemsSource="{Binding PostingPreviewLines}"
                                              Visibility="{Binding PostingPreviewVisibility}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Spacing="8"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding AccentBackgroundBrush}"
                                                    CornerRadius="14"
                                                    Padding="12">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding SideText}" Foreground="{Binding AccentBrush}" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding AccountText}" FontWeight="SemiBold" TextWrapping="WrapWholeWords"/>
                                                    <TextBlock Text="{Binding AmountText}" Foreground="{Binding AccentBrush}" FontSize="16" FontWeight="Bold" Language="en-US"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="الرصيد قبل وبعد" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>

                                <Border Style="{StaticResource VoucherDialogInfoCardStyle}"
                                        Visibility="{Binding BalancePreviewPlaceholderVisibility}">
                                    <TextBlock Text="سيظهر أثر التحويل على رصيد الحسابين بعد اكتمال البيانات الأساسية."
                                               Style="{StaticResource VoucherDialogHintTextStyle}"/>
                                </Border>

                                <ItemsControl ItemsSource="{Binding BalancePreviewCards}"
                                              Visibility="{Binding BalancePreviewVisibility}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Spacing="8"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource VoucherDialogInfoCardStyle}">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Label}" Foreground="{Binding AccentBrush}" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding AccountText}" FontWeight="SemiBold" TextWrapping="WrapWholeWords"/>
                                                    <TextBlock Text="{Binding MovementText}" Foreground="{Binding AccentBrush}" FontSize="12" TextWrapping="WrapWholeWords"/>
                                                    <TextBlock Text="{Binding BeforeBalanceText}" Foreground="{StaticResource SlateTextBrush}" FontSize="12" TextWrapping="WrapWholeWords"/>
                                                    <TextBlock Text="{Binding AfterBalanceText}" Foreground="{Binding AccentBrush}" FontWeight="SemiBold" FontSize="12" TextWrapping="WrapWholeWords"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>

                        <Border Background="#FEF2F2"
                                BorderBrush="#FECACA"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12,10"
                                Visibility="{Binding PreviewErrorVisibility}">
                            <TextBlock Text="{Binding PreviewErrorMessage}"
                                       Foreground="#DC2626"
                                       TextWrapping="WrapWholeWords"/>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                x:Name="ErrorBanner"
                Background="#FEF2F2"
                BorderBrush="#FECACA"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14,12"
                Visibility="Collapsed">
            <TextBlock x:Name="ErrorText"
                       Foreground="#DC2626"
                       TextWrapping="WrapWholeWords"/>
        </Border>

        <Border Grid.Row="3"
                Style="{StaticResource VoucherDialogFooterCardStyle}">
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="2"
                            VerticalAlignment="Center">
                    <TextBlock Text="قيمة التحويل"
                               Style="{StaticResource VoucherDialogMetricLabelStyle}"/>
                    <TextBlock Text="{Binding EquivalentAmountText}"
                               Style="{StaticResource VoucherDialogMetricValueStyle}"
                               Foreground="#4338CA"
                               Language="en-US"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="إغلاق"
                        Click="CancelButton_Click"
                        Style="{StaticResource SecondaryActionCompactButtonStyle}"
                        MinWidth="96"/>

                <Button Grid.Column="2"
                        Click="EditButton_Click"
                        Visibility="{Binding ViewManageButtonsVisibility}"
                        Style="{StaticResource SecondaryActionCompactButtonStyle}"
                        Content="{Binding EditButtonText}"
                        MinWidth="110"/>

                <Button Grid.Column="3"
                        Click="DeleteButton_Click"
                        Visibility="{Binding DeleteButtonVisibility}"
                        Style="{StaticResource SecondaryActionCompactButtonStyle}"
                        Content="{Binding DeleteButtonText}"
                        MinWidth="104"/>

                <Button Grid.Column="4"
                        Click="SaveDraftButton_Click"
                        Visibility="{Binding SaveDraftButtonVisibility}"
                        Style="{StaticResource SecondaryActionCompactButtonStyle}"
                        Content="{Binding SaveDraftButtonText}"
                        MinWidth="126"/>

                <Button Grid.Column="5"
                        Click="SaveAndPostButton_Click"
                        Visibility="{Binding SaveAndPostButtonVisibility}"
                        Style="{StaticResource PrimaryActionCompactButtonStyle}"
                        Content="{Binding SaveAndPostButtonText}"
                        MinWidth="132"/>

                <Button Grid.Column="6"
                        Click="SaveChangesButton_Click"
                        Visibility="{Binding SaveChangesButtonVisibility}"
                        Style="{StaticResource PrimaryActionCompactButtonStyle}"
                        Content="{Binding SaveChangesButtonText}"
                        MinWidth="132"/>

                <TextBlock Grid.Column="7"
                           Text="{Binding FooterHintText}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="11"
                           TextWrapping="WrapWholeWords"/>
            </Grid>
        </Border>
    </Grid>
</ContentDialog>
