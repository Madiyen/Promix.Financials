<ContentDialog
    x:Class="Promix.Financials.UI.Dialogs.Journals.TransferVoucherDialog"
    x:Name="RootDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Promix.Financials.UI.Controls.Journals"
    Title=""
    PrimaryButtonText="حفظ كمسودة"
    SecondaryButtonText="حفظ وترحيل"
    CloseButtonText="إلغاء"
    DefaultButton="Secondary"
    FlowDirection="RightToLeft"
    RequestedTheme="Light"
    FullSizeDesired="True"
    MinWidth="1500"
    MaxWidth="1650">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">1650</x:Double>
        <x:Double x:Key="ContentDialogMinWidth">1500</x:Double>
    </ContentDialog.Resources>

    <ScrollViewer MaxHeight="760"
                  MinWidth="1480"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="14">
            <Border CornerRadius="24" Padding="20" MinHeight="118">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E1B4B" Offset="0"/>
                        <GradientStop Color="#4338CA" Offset="0.55"/>
                        <GradientStop Color="#818CF8" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="92"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Background="#312E81" CornerRadius="12" Padding="10,6">
                                <TextBlock Text="{Binding EffectBadgeText}" Foreground="White" Style="{StaticResource VoucherDialogBadgeTextStyle}"/>
                            </Border>
                            <TextBlock Text="تحويل بين الحسابات" Foreground="White" FontSize="24" FontWeight="Bold"/>
                        </StackPanel>

                        <TextBlock Text="انقل الرصيد بين الصندوق والخزينة أو بين أي حسابين نقديين من شاشة أفقية سريعة وواضحة."
                                   Foreground="#E0E7FF"
                                   FontSize="13"
                                   MaxWidth="760"
                                   TextWrapping="WrapWholeWords"/>

                        <TextBlock Text="{Binding EffectSummaryText}"
                                   Foreground="White"
                                   FontSize="12"
                                   TextWrapping="WrapWholeWords"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Width="76"
                            Height="76"
                            CornerRadius="38"
                            Background="#312E81"
                            HorizontalAlignment="Right">
                        <FontIcon Glyph="&#xE8AB;"
                                  Foreground="White"
                                  FontSize="30"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="14">
                    <Border Style="{StaticResource VoucherDialogCardStyle}">
                        <StackPanel Spacing="14">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="أطراف التحويل" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>
                                    <TextBlock Text="حدّد حساب المصدر والحساب المستلم، وسيحسب النظام أثر النقل على كل طرف مباشرة."
                                               Style="{StaticResource VoucherDialogSubtleTextStyle}"/>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Style="{StaticResource VoucherDialogInfoCardStyle}"
                                        Background="#EEF2FF"
                                        BorderBrush="#C7D2FE">
                                    <TextBlock Text="القيد الناتج سيكون من سطرين: المستلم مدين، والمحوِّل دائن."
                                               Foreground="#3730A3"
                                               Style="{StaticResource VoucherDialogHintTextStyle}"
                                               Width="180"/>
                                </Border>
                            </Grid>

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.15*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="10">
                                    <controls:AccountLookupBox Header="من حساب"
                                                               PlaceholderText="يظهر الصندوق افتراضياً عند توفره"
                                                               ItemsSource="{Binding TransferAccountOptions}"
                                                               SelectedAccountId="{Binding SelectedSourceAccountId, Mode=TwoWay}"/>
                                    <TextBlock Text="{Binding SourceGuideText}" Style="{StaticResource VoucherDialogHintTextStyle}" Margin="4,0,0,0"/>

                                    <controls:AccountLookupBox Header="إلى حساب"
                                                               PlaceholderText="تظهر الخزينة الرئيسية افتراضياً عند توفرها"
                                                               ItemsSource="{Binding TransferAccountOptions}"
                                                               SelectedAccountId="{Binding SelectedTargetAccountId, Mode=TwoWay}"/>
                                    <TextBlock Text="{Binding TargetGuideText}" Style="{StaticResource VoucherDialogHintTextStyle}" Margin="4,0,0,0"/>
                                </StackPanel>

                                <Grid Grid.Column="1" ColumnSpacing="12" RowSpacing="12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                                        <TextBlock Text="العملة" Style="{StaticResource FieldLabelStyle}"/>
                                        <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                                  ItemsSource="{Binding CurrencyOptions}"
                                                  DisplayMemberPath="DisplayText"
                                                  SelectedValuePath="CurrencyCode"
                                                  SelectedValue="{Binding SelectedCurrencyCode, Mode=TwoWay}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                                        <TextBlock Text="التاريخ" Style="{StaticResource FieldLabelStyle}"/>
                                        <DatePicker Style="{StaticResource InputDatePickerStyle}"
                                                    Date="{Binding EntryDate, Mode=TwoWay}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="6">
                                        <TextBlock Text="سعر الصرف" Style="{StaticResource FieldLabelStyle}"/>
                                        <NumberBox Style="{StaticResource InputNumberBoxStyle}"
                                                   Value="{Binding ExchangeRate, Mode=TwoWay}"
                                                   IsEnabled="{Binding CanEditExchangeRate}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                                        <TextBlock Text="المبلغ بالعملة" Style="{StaticResource FieldLabelStyle}"/>
                                        <NumberBox Style="{StaticResource InputNumberBoxStyle}"
                                                   Value="{Binding Amount, Mode=TwoWay}"/>
                                    </StackPanel>

                                    <Border Grid.Row="2"
                                            Grid.ColumnSpan="2"
                                            Style="{StaticResource VoucherDialogInfoCardStyle}"
                                            Background="#EEF2FF"
                                            BorderBrush="#C7D2FE">
                                        <Grid ColumnSpacing="14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Glyph="&#xE9D2;" Foreground="#4338CA" FontSize="20" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Spacing="3">
                                                <TextBlock Text="{Binding EquivalentLabel}" Style="{StaticResource VoucherDialogHintTextStyle}" Foreground="#4338CA"/>
                                                <TextBlock Text="{Binding EquivalentAmount}" Foreground="#0F172A" FontSize="20" FontWeight="Bold"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource VoucherDialogCardStyle}">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.9*"/>
                                <ColumnDefinition Width="1.35*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="12">
                                <TextBlock Text="المرجع" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="رقم مرجعي" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Style="{StaticResource InputTextBoxStyle}"
                                             Text="{Binding ReferenceNo, Mode=TwoWay}"
                                             PlaceholderText="اختياري"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="10">
                                <TextBlock Text="البيان" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>
                                <TextBox Style="{StaticResource MultilineTextBoxStyle}"
                                         Text="{Binding Description, Mode=TwoWay}"
                                         Height="96"
                                         PlaceholderText="مثال: تحويل رصيد من الصندوق إلى الأموال الجاهزة"/>
                                <Border Style="{StaticResource VoucherDialogInfoCardStyle}">
                                    <TextBlock Text="{Binding DescriptionGuideText}" Style="{StaticResource VoucherDialogHintTextStyle}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="14">
                    <Border Style="{StaticResource VoucherDialogCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="إشارة سريعة" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>
                            <Border Style="{StaticResource VoucherDialogInfoCardStyle}"
                                    Background="#EEF2FF"
                                    BorderBrush="#C7D2FE">
                                <TextBlock Text="{Binding PreviewNoteText}" Foreground="#3730A3" Style="{StaticResource VoucherDialogSubtleTextStyle}"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource VoucherDialogCardStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="القيد الناتج" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>
                            <Border Style="{StaticResource VoucherDialogInfoCardStyle}"
                                    Visibility="{Binding PostingPreviewPlaceholderVisibility}">
                                <TextBlock Text="ستظهر أسطر قيد التحويل هنا بعد اختيار الحساب المصدر والمستلم وإدخال مبلغ صالح."
                                           Style="{StaticResource VoucherDialogHintTextStyle}"/>
                            </Border>

                            <ItemsControl ItemsSource="{Binding PostingPreviewLines}"
                                          Visibility="{Binding PostingPreviewVisibility}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="10"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding AccentBackgroundBrush}" CornerRadius="14" Padding="12">
                                            <StackPanel Spacing="6">
                                                <Border Background="{Binding AccentBrush}" CornerRadius="10" Padding="8,4" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding SideText}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                </Border>
                                                <TextBlock Text="{Binding AccountText}" FontWeight="SemiBold" TextWrapping="WrapWholeWords"/>
                                                <TextBlock Text="{Binding AmountText}" Foreground="{Binding AccentBrush}" FontSize="18" FontWeight="Bold"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource VoucherDialogCardStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="الرصيد قبل وبعد" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>
                            <Border Style="{StaticResource VoucherDialogInfoCardStyle}"
                                    Visibility="{Binding BalancePreviewPlaceholderVisibility}">
                                <TextBlock Text="سيظهر أثر التحويل على رصيد الحسابين مباشرة بعد اكتمال البيانات."
                                           Style="{StaticResource VoucherDialogHintTextStyle}"/>
                            </Border>

                            <ItemsControl ItemsSource="{Binding BalancePreviewCards}"
                                          Visibility="{Binding BalancePreviewVisibility}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="10"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource VoucherDialogInfoCardStyle}">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="{Binding Label}" Foreground="{Binding AccentBrush}" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding AccountText}" FontWeight="SemiBold" TextWrapping="WrapWholeWords"/>
                                                <TextBlock Text="{Binding MovementText}" Foreground="{Binding AccentBrush}" FontSize="12"/>
                                                <TextBlock Text="{Binding BeforeBalanceText}" Foreground="{StaticResource SlateTextBrush}" FontSize="12"/>
                                                <TextBlock Text="{Binding AfterBalanceText}" Foreground="{Binding AccentBrush}" FontWeight="SemiBold" FontSize="12"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Background="#FEF2F2"
                            BorderBrush="#FECACA"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12,10"
                            Visibility="{Binding PreviewErrorVisibility}">
                        <TextBlock Text="{Binding PreviewErrorMessage}" Foreground="#DC2626" TextWrapping="WrapWholeWords"/>
                    </Border>
                </StackPanel>
            </Grid>

            <Border x:Name="ErrorBanner"
                    Background="#FEF2F2"
                    BorderBrush="#FECACA"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14,12"
                    Visibility="Collapsed">
                <TextBlock x:Name="ErrorText" Foreground="#DC2626" TextWrapping="WrapWholeWords"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
