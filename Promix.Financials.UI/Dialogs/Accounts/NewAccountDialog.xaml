<ContentDialog
    x:Class="Promix.Financials.UI.Dialogs.Accounts.NewAccountDialog"
    x:Name="RootDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:Promix.Financials.UI.Converters"
    mc:Ignorable="d"
    FlowDirection="RightToLeft"
    Title=""
    Background="Transparent"
    FullSizeDesired="True"
    HorizontalContentAlignment="Stretch"
    VerticalContentAlignment="Stretch">

    <ContentDialog.Resources>
        <converters:BoolToCollapsedVisibilityConverter x:Key="BoolToCollapsedVisibilityConverter"/>
        <converters:EmptyToCollapsedConverter x:Key="EmptyToCollapsedConverter"/>
        <x:Double x:Key="ContentDialogMaxWidth">920</x:Double>
        <x:Double x:Key="ContentDialogMinWidth">860</x:Double>
    </ContentDialog.Resources>

    <Grid Width="860" MaxWidth="920" MaxHeight="710" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="18"
                Padding="18"
                MinHeight="110">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1E3A5F" Offset="0"/>
                    <GradientStop Color="#1D4ED8" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="68"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <Border Width="52"
                        Height="52"
                        Background="#1E40AF"
                        CornerRadius="16"
                        VerticalAlignment="Top">
                    <FontIcon Glyph="&#xE8A0;"
                              Foreground="White"
                              FontSize="24"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1"
                            Spacing="4"
                            VerticalAlignment="Center">
                    <Border Background="#2563EB"
                            CornerRadius="12"
                            Padding="10,4"
                            HorizontalAlignment="Right">
                        <TextBlock Text="حساب جديد"
                                   Foreground="White"
                                   Style="{StaticResource VoucherDialogBadgeTextStyle}"/>
                    </Border>

                    <TextBlock Text="إضافة حساب إلى شجرة الحسابات"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"/>

                    <TextBlock Text="{Binding ParentGuideText}"
                               Foreground="#DBEAFE"
                               FontSize="11.5"
                               TextWrapping="WrapWholeWords"/>
                </StackPanel>

                <Border Grid.Column="2"
                        Background="#1AFFFFFF"
                        BorderBrush="#22FFFFFF"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="12"
                        VerticalAlignment="Center">
                    <StackPanel Spacing="4">
                        <TextBlock Text="ملخص التوليد"
                                   Foreground="#BFDBFE"
                                   FontSize="10.5"/>
                        <TextBlock Text="{Binding SuggestedCode}"
                                   Foreground="White"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Language="en-US"/>
                        <TextBlock Text="{Binding DerivedCategoryText}"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding DerivedNatureText}"
                                   Foreground="#DBEAFE"
                                   FontSize="11.5"/>
                        <TextBlock Text="{Binding DerivedCloseBehaviorText}"
                                   Foreground="#DBEAFE"
                                   FontSize="11.5"/>
                        <TextBlock Text="{Binding DerivedLevelText}"
                                   Foreground="#DBEAFE"
                                   FontSize="11.5"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      ZoomMode="Disabled">
            <StackPanel Spacing="12">
                <Border Style="{StaticResource VoucherDialogCardStyle}">
                    <StackPanel Spacing="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="3">
                                <TextBlock Text="الهيكل والترقيم" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>
                                <TextBlock Text="اختر الحساب الأب ليولد النظام الكود الهرمي تلقائياً حسب موقع الحساب الجديد."
                                           Style="{StaticResource VoucherDialogSubtleTextStyle}"/>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Background="#EFF6FF"
                                    BorderBrush="#BFDBFE"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10,5"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding DerivedLevelText}"
                                           Foreground="#1D4ED8"
                                           Style="{StaticResource VoucherDialogBadgeTextStyle}"/>
                            </Border>
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="الحساب الأب" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                          ItemsSource="{Binding ParentAccounts}"
                                          SelectedItem="{Binding SelectedParentAccount, Mode=TwoWay}"
                                          DisplayMemberPath="DisplayName"
                                          PlaceholderText="(جذر الشجرة)"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="الكود المولد" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}"
                                         Text="{Binding SuggestedCode, Mode=OneWay}"
                                         IsReadOnly="True"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource VoucherDialogCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="تعريف الحساب" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Style="{StaticResource FieldLabelStyle}">
                                    <Run Text="الاسم العربي"/>
                                    <Run Text=" *" Foreground="#DC2626"/>
                                </TextBlock>
                                <TextBox Style="{StaticResource InputTextBoxStyle}"
                                         Text="{Binding ArabicName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="مثال: الصندوق الرئيسي"/>
                                <TextBlock Text="{Binding ArabicNameError}"
                                           Style="{StaticResource ErrorLabelStyle}"
                                           Visibility="{Binding IsArabicNameValid, Converter={StaticResource BoolToCollapsedVisibilityConverter}}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="الاسم بالإنكليزية" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Style="{StaticResource InputTextBoxStyle}"
                                         Text="{Binding EnglishName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         FlowDirection="LeftToRight"
                                         PlaceholderText="e.g. Main Cash"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource VoucherDialogCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="الخصائص المحاسبية" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="نوع الحساب" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                          ItemsSource="{Binding AccountTypes}"
                                          SelectedItem="{Binding SelectedAccountType, Mode=TwoWay}"/>
                                <TextBlock Text="{Binding PostingModeHintText}"
                                           Style="{StaticResource HintLabelStyle}"
                                           TextWrapping="WrapWholeWords"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="العملة" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                          ItemsSource="{Binding Currencies}"
                                          SelectedItem="{Binding SelectedCurrency, Mode=TwoWay}"
                                          DisplayMemberPath="DisplayName"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="#EFF6FF"
                                    BorderBrush="#BFDBFE"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="12,10">
                                <StackPanel Spacing="3">
                                    <TextBlock Text="الفئة" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding DerivedCategoryText}" Foreground="#1D4ED8" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Background="#ECFDF5"
                                    BorderBrush="#BBF7D0"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="12,10">
                                <StackPanel Spacing="3">
                                    <TextBlock Text="الطبيعة" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding DerivedNatureText}" Foreground="#166534" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Background="#FFF7ED"
                                    BorderBrush="#FED7AA"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="12,10">
                                <StackPanel Spacing="3">
                                    <TextBlock Text="الإقفال" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding DerivedCloseBehaviorText}" Foreground="#C2410C" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource VoucherDialogCardStyle}">
                    <StackPanel Spacing="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="3">
                                <TextBlock Text="إعدادات متقدمة" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>
                                <TextBlock Text="هذه الإعدادات مخصصة للحسابات المرجعية التي يعتمد عليها النظام في الوحدات المختلفة. في أغلب الحسابات اليومية يمكنك تركها فارغة."
                                           Style="{StaticResource VoucherDialogSubtleTextStyle}"
                                           TextWrapping="WrapWholeWords"/>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Background="#FFF7ED"
                                    BorderBrush="#FED7AA"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10,5"
                                    VerticalAlignment="Top">
                                <TextBlock Text="اختياري"
                                           Foreground="#C2410C"
                                           Style="{StaticResource VoucherDialogBadgeTextStyle}"/>
                            </Border>
                        </Grid>

                        <Border Background="#EFF6FF"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="الدور النظامي"
                                           Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                          ItemsSource="{Binding SystemRoles}"
                                          SelectedItem="{Binding SelectedSystemRole, Mode=TwoWay}"
                                          PlaceholderText="بدون"/>
                                <TextBlock Text="مثال: الصندوق الرئيسي أو البنك أو ذمم العملاء أو المبيعات. اتركه فارغًا إذا كان هذا الحساب عاديًا ولا تريد أن يستخدمه النظام تلقائيًا."
                                           Style="{StaticResource HintLabelStyle}"
                                           TextWrapping="WrapWholeWords"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource VoucherDialogCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="ملاحظات وحالة" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="170"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="ملاحظات" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Style="{StaticResource MultilineTextBoxStyle}"
                                         Text="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Height="88"
                                         PlaceholderText="أي ملاحظات إضافية تخص هذا الحساب"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="الحالة" Style="{StaticResource FieldLabelStyle}"/>
                                <Button x:Name="NewAccountActiveStateButton"
                                        Click="NewAccountActiveStateButton_Click"
                                        Style="{StaticResource FilterChipButtonStyle}"
                                        Content="نشط"/>
                                <Button x:Name="NewAccountInactiveStateButton"
                                        Click="NewAccountInactiveStateButton_Click"
                                        Style="{StaticResource FilterChipButtonStyle}"
                                        Content="موقوف"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border x:Name="ErrorBanner"
                Grid.Row="2"
                Style="{StaticResource InlineErrorBannerStyle}"
                Visibility="{Binding ArabicNameError, Converter={StaticResource EmptyToCollapsedConverter}}">
            <TextBlock Text="{Binding ArabicNameError}"
                       Foreground="#B91C1C"
                       FontSize="12"
                       TextWrapping="WrapWholeWords"/>
        </Border>

        <Border Grid.Row="3"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="14">
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        x:Name="CancelFooterButton"
                        Click="CancelButton_Click"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        Content="إلغاء"/>

                <Button Grid.Column="1"
                        x:Name="SaveFooterButton"
                        Click="SaveButton_Click"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        Content="حفظ الحساب"/>

                <TextBlock Grid.Column="2"
                           Text="سيُنشئ النظام الحساب بالكود الهرمي المقترح ويضيفه مباشرة تحت الفرع المختار."
                           Style="{StaticResource VoucherDialogHintTextStyle}"
                           VerticalAlignment="Center"
                           TextWrapping="WrapWholeWords"
                           HorizontalAlignment="Left"/>
            </Grid>
        </Border>
    </Grid>
</ContentDialog>
