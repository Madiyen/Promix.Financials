<ContentDialog
    x:Class="Promix.Financials.UI.Dialogs.Accounts.EditAccountDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Promix.Financials.UI.Converters"
    FlowDirection="RightToLeft"
    Background="Transparent"
    FullSizeDesired="True"
    HorizontalContentAlignment="Stretch"
    VerticalContentAlignment="Stretch"
    Title=""
    PrimaryButtonText="حفظ التعديلات"
    CloseButtonText="إلغاء"
    DefaultButton="Primary">

    <ContentDialog.Resources>
        <converters:BoolToCollapsedVisibilityConverter x:Key="BoolToCollapsedVisibilityConverter"/>
    </ContentDialog.Resources>

    <Grid Width="780" MaxWidth="820" MaxHeight="700" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="18" Padding="18" MinHeight="116">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1E3A5F" Offset="0"/>
                    <GradientStop Color="#0F766E" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="52" Height="52" Background="#115E59" CornerRadius="16">
                            <FontIcon Glyph="&#xE70F;" Foreground="White" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="4">
                            <Border Background="#0F766E" CornerRadius="12" Padding="10,4" HorizontalAlignment="Right">
                                <TextBlock Text="تعديل" Style="{StaticResource VoucherDialogBadgeTextStyle}" Foreground="White"/>
                            </Border>
                            <TextBlock Text="تعديل الحساب" Foreground="White" FontSize="23" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="{Binding UsageHeadline}"
                               Foreground="#CCFBF1"
                               FontSize="12"
                               TextWrapping="WrapWholeWords"
                               MaxWidth="500"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#140B1220"
                        BorderBrush="#33CCFBF1"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="14">
                    <StackPanel Spacing="6">
                        <TextBlock Text="ملخص الحساب" Foreground="#99F6E4" FontSize="10.5"/>
                        <TextBlock Text="{Binding Code}" Foreground="White" FontSize="22" FontWeight="Bold" Language="en-US"/>
                        <TextBlock Text="{Binding ClassificationText}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding NatureText}" Foreground="#CCFBF1" FontSize="11.5"/>
                        <TextBlock Text="{Binding BalanceText}" Foreground="#CCFBF1" FontSize="11.5" Language="en-US"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="12">
                <Border Style="{StaticResource VoucherDialogCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="معلومات ثابتة" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="8">
                                <StackPanel Spacing="3"><TextBlock Text="الحساب الأب" Style="{StaticResource FieldLabelStyle}"/><TextBlock Text="{Binding ParentDisplay}"/></StackPanel>
                                <StackPanel Spacing="3"><TextBlock Text="نوع الحساب" Style="{StaticResource FieldLabelStyle}"/><TextBlock Text="{Binding TypeText}"/></StackPanel>
                                <StackPanel Spacing="3"><TextBlock Text="الطبيعة" Style="{StaticResource FieldLabelStyle}"/><TextBlock Text="{Binding NatureText}"/></StackPanel>
                                <StackPanel Spacing="3"><TextBlock Text="الفئة" Style="{StaticResource FieldLabelStyle}"/><TextBlock Text="{Binding ClassificationText}"/></StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="8">
                                <StackPanel Spacing="3"><TextBlock Text="المستوى" Style="{StaticResource FieldLabelStyle}"/><TextBlock Text="{Binding LevelText}"/></StackPanel>
                                <StackPanel Spacing="3"><TextBlock Text="الإقفال" Style="{StaticResource FieldLabelStyle}"/><TextBlock Text="{Binding CloseBehaviorText}"/></StackPanel>
                                <StackPanel Spacing="3"><TextBlock Text="العملة" Style="{StaticResource FieldLabelStyle}"/><TextBlock Text="{Binding CurrencyDisplay}" Language="en-US"/></StackPanel>
                                <StackPanel Spacing="3"><TextBlock Text="الدور النظامي" Style="{StaticResource FieldLabelStyle}"/><TextBlock Text="{Binding SystemRoleText}"/></StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource VoucherDialogCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="البيانات القابلة للتعديل" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Style="{StaticResource FieldLabelStyle}">
                                    <Run Text="الاسم العربي"/>
                                    <Run Text=" *" Foreground="#DC2626"/>
                                </TextBlock>
                                <TextBox Text="{Binding ArabicName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         PlaceholderText="أدخل الاسم العربي"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="الاسم الإنكليزي" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding EnglishName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         FlowDirection="LeftToRight"
                                         PlaceholderText="English name"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="4">
                            <TextBlock Text="ملاحظات" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MultilineTextBoxStyle}"
                                     Height="88"
                                     PlaceholderText="ملاحظات إضافية على الحساب"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="الحالة" Style="{StaticResource FieldLabelStyle}"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="EditAccountActiveStateButton"
                                        Click="EditAccountActiveStateButton_Click"
                                        Style="{StaticResource FilterChipButtonStyle}"
                                        Content="نشط"/>
                                <Button x:Name="EditAccountInactiveStateButton"
                                        Click="EditAccountInactiveStateButton_Click"
                                        Style="{StaticResource FilterChipButtonStyle}"
                                        Content="موقوف"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource VoucherDialogCardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="الارتباطات والاستخدامات" Style="{StaticResource VoucherDialogSectionTitleStyle}"/>
                        <ItemsControl ItemsSource="{Binding UsageBadges}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapGrid MaximumRowsOrColumns="4" Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F1F5F9"
                                            BorderBrush="#D6E0EB"
                                            BorderThickness="1"
                                            CornerRadius="999"
                                            Padding="10,5"
                                            Margin="0,0,8,8">
                                        <TextBlock Text="{Binding}" FontSize="11.5" Foreground="{StaticResource SecondaryTextBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Background="#FEF3C7"
                                BorderBrush="#FCD34D"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12,10"
                                Visibility="{Binding IsSystemAccount, Converter={StaticResource BoolToCollapsedVisibilityConverter}}">
                            <TextBlock Text="هذا حساب يدوي ويمكن تعديل اسمه وملاحظاته وحالته ما دامت قواعد الاستخدام تسمح بذلك."
                                       Foreground="#92400E"
                                       TextWrapping="WrapWholeWords"/>
                        </Border>

                        <ItemsControl ItemsSource="{Binding BlockingReasons}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FEF2F2"
                                            BorderBrush="#FECACA"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="10,8"
                                            Margin="0,0,0,6">
                                        <TextBlock Text="{Binding}" Foreground="#B91C1C" FontSize="12" TextWrapping="WrapWholeWords"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ContentDialog>
