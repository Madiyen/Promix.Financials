<ContentDialog
    x:Class="Promix.Financials.UI.Dialogs.CommandPaletteDialog"
    x:Name="RootDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title=""
    Background="Transparent"
    RequestedTheme="Light"
    FlowDirection="RightToLeft"
    FullSizeDesired="False"
    HorizontalContentAlignment="Stretch"
    VerticalContentAlignment="Stretch">

    <Grid Width="760" MaxWidth="820" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource AppSurfaceCardCompactStyle}"
                Padding="16,14">
            <StackPanel Spacing="10">
                <TextBlock Text="لوحة الأوامر"
                           Style="{StaticResource AppSectionTitleTextStyle}"/>

                <AutoSuggestBox x:Name="CommandSearchBox"
                                PlaceholderText="ابحث عن شاشة أو أمر أو حساب..."
                                TextChanged="CommandSearchBox_TextChanged"
                                QuerySubmitted="CommandSearchBox_QuerySubmitted">
                    <AutoSuggestBox.QueryIcon>
                        <SymbolIcon Symbol="Find"/>
                    </AutoSuggestBox.QueryIcon>
                </AutoSuggestBox>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource AppEnterpriseInfoChipStyle}"
                HorizontalAlignment="Right">
            <TextBlock Text="Enter للتنفيذ  •  Esc للإغلاق"
                       Style="{StaticResource AppEnterpriseInfoChipTextStyle}"/>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource AppSurfaceCardCompactStyle}"
                Padding="8">
            <Grid>
                <ListView x:Name="ResultsList"
                          Background="Transparent"
                          BorderThickness="0"
                          SelectionMode="Single"
                          IsItemClickEnabled="True"
                          ItemClick="ResultsList_ItemClick"
                          KeyDown="ResultsList_KeyDown">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource AppSelectableListViewItemStyle}">
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="MinHeight" Value="56"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="34"
                                        Height="34"
                                        CornerRadius="10"
                                        Background="{StaticResource AppSubtleSurfaceBrush}">
                                    <FontIcon Glyph="{Binding Glyph}"
                                              Foreground="{StaticResource PrimaryButtonBrush}"
                                              FontSize="15"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Spacing="2"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource MainTitleTextBrush}"/>
                                    <TextBlock Text="{Binding Subtitle}"
                                               Foreground="{StaticResource SlateTextBrush}"
                                               FontSize="11.5"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Border x:Name="EmptyState"
                        Style="{StaticResource AppEmptyStateCardStyle}"
                        Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8">
                        <FontIcon Glyph="&#xE721;"
                                  FontSize="34"
                                  Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="لا توجد نتائج مطابقة"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="جرّب كتابة اسم شاشة أو سند أو كود حساب."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</ContentDialog>
