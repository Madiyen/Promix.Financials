<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════
         TextBox — حقل إدخال نصي
    ═══════════════════════════════════════ -->
    <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#94A3B8"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinHeight" Value="40"/>
    </Style>

    <!-- TextBox للقراءة فقط (الكود التلقائي) -->
    <Style x:Key="ReadOnlyTextBoxStyle" TargetType="TextBox"
           BasedOn="{StaticResource InputTextBoxStyle}">
        <Setter Property="Background" Value="#F1F5F9"/>
        <Setter Property="BorderBrush" Value="#CBD5E1"/>
        <Setter Property="Foreground" Value="#2563EB"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <!-- TextBox متعدد الأسطر (الملاحظات) -->
    <Style x:Key="MultilineTextBoxStyle" TargetType="TextBox"
           BasedOn="{StaticResource InputTextBoxStyle}">
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="AcceptsReturn" Value="True"/>
        <Setter Property="MinHeight" Value="72"/>
    </Style>

    <!-- ═══════════════════════════════════════
         ComboBox — قائمة منسدلة
    ═══════════════════════════════════════ -->
    <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#94A3B8"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <!-- ═══════════════════════════════════════
         SearchBox — مربع البحث
    ═══════════════════════════════════════ -->
    <Style x:Key="SearchBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="4,0"/>
    </Style>

    <!-- ═══════════════════════════════════════
         Label — عنوان الحقل
    ══════════════════════════════��════════ -->
    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#475569"/>
    </Style>

    <!-- Label للخطأ -->
    <Style x:Key="ErrorLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="#DC2626"/>
    </Style>

    <!-- Label للتلميح -->
    <Style x:Key="HintLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="#94A3B8"/>
        <Setter Property="FontStyle" Value="Italic"/>
    </Style>

</ResourceDictionary>