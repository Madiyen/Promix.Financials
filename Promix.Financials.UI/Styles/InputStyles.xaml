<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">

    <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="MinHeight" Value="42"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="PlaceholderForeground" Value="{StaticResource SlateTextBrush}"/>
        <Setter Property="SelectionHighlightColor" Value="#BFDBFE"/>
    </Style>

    <Style x:Key="ReadOnlyTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputTextBoxStyle}">
        <Setter Property="Background" Value="#F3F7FC"/>
        <Setter Property="BorderBrush" Value="#D7E3F2"/>
        <Setter Property="Foreground" Value="#1D4ED8"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="MultilineTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputTextBoxStyle}">
        <Setter Property="MinHeight" Value="84"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="AcceptsReturn" Value="True"/>
        <Setter Property="VerticalContentAlignment" Value="Top"/>
    </Style>

    <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="MinHeight" Value="42"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="Padding" Value="12,4"/>
    </Style>

    <Style x:Key="InputAutoSuggestBoxStyle" TargetType="AutoSuggestBox">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="MinHeight" Value="42"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
    </Style>

    <Style x:Key="InputNumberBoxStyle" TargetType="controls:NumberBox">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="MinHeight" Value="42"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
    </Style>

    <Style x:Key="InputDatePickerStyle" TargetType="DatePicker">
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="MinHeight" Value="42"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
    </Style>

    <Style x:Key="InputToggleSwitchStyle" TargetType="ToggleSwitch">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="OnContent" Value="نشط"/>
        <Setter Property="OffContent" Value="موقوف التعامل"/>
    </Style>

    <Style x:Key="SearchBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputTextBoxStyle}">
        <Setter Property="Padding" Value="4,0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
    </Style>

    <Style x:Key="ErrorLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11.5"/>
        <Setter Property="Foreground" Value="#DC2626"/>
    </Style>

    <Style x:Key="HintLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11.5"/>
        <Setter Property="Foreground" Value="{StaticResource SlateTextBrush}"/>
    </Style>

    <Style TargetType="TextBox" BasedOn="{StaticResource InputTextBoxStyle}"/>
    <Style TargetType="ComboBox" BasedOn="{StaticResource InputComboBoxStyle}"/>
    <Style TargetType="AutoSuggestBox" BasedOn="{StaticResource InputAutoSuggestBoxStyle}"/>
    <Style TargetType="controls:NumberBox" BasedOn="{StaticResource InputNumberBoxStyle}"/>
    <Style TargetType="DatePicker" BasedOn="{StaticResource InputDatePickerStyle}"/>
    <Style TargetType="ToggleSwitch" BasedOn="{StaticResource InputToggleSwitchStyle}"/>

</ResourceDictionary>
